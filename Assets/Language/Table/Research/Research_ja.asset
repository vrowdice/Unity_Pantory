  m_TableData:
  - m_Id: 864226266001
    m_Localized: "電子部品"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266002
    m_Localized: "採掘"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266003
    m_Localized: "化学処理"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266004
    m_Localized: "重工業"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266005
    m_Localized: "石油採掘"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266006
    m_Localized: "金属精錬"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266007
    m_Localized: "エンジン製造"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266008
    m_Localized: "軍事生産"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266009
    m_Localized: "車両組立"
    m_Metadata:
      m_Items: []
  - m_Id: 10606215174701056
    m_Localized: "工場基本"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267001
    m_Localized: "電子部品工場を解禁。銅・アルミインゴットから電子部品を生産。エンジンや先進生産に必要。"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267002
    m_Localized: "専用鉱山（鉄・石炭・銅・アルミ）を解禁。各鉱山は1種類の鉱石のみ採掘。金鉱石は別途金鉱山研究が必要。建設・維持コストは高い。"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267003
    m_Localized: "化学プラントを解禁。原油を消費し織物を生産し、製材所の木材チェーンを補完する。"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267004
    m_Localized: "重工場を解禁。織物と金鉱石から高級衣顗、高級木材・織物・機械部品から高級家具を生産。高級市場向けの高投資。"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267005
    m_Localized: "石油ポンプを解禁。地下から原油を採掘。維持費は非常に高く、化学プラントや燃料生産の基盤。完了で化学処理研究が解禁される。"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267006
    m_Localized: "製錬所を解禁。鉄・銅・アルミ鉱石をインゴットに、金鉱石を純金に加工。金属・電子チェーンの要。"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267007
    m_Localized: "エンジン工場を解禁。機械部品・電子部品・鋼インゴットでエンジンを生産。車両組立の前提。"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267008
    m_Localized: "軍事工場を解禁。鋼材・機械部品・良木・石炭などで小火器・重火器・弾薬を生産。"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267009
    m_Localized: "車両組立工場を解禁。エンジン・鋼材・電子・アルミ・石油・兵器などから自動車・戦闘機・戦車を生産。最高付加価値だが最も複雑。"
    m_Metadata:
      m_Items: []
  - m_Id: 10166970572226560
    m_Localized: "工場運営の基礎研究。軽工場と積込ステーションを解禁し、採掘・製錬・石油採掘の研究も開放する。"
    m_Metadata:
      m_Items: []
  - m_Id: 22606259738263552
    m_Localized: "建物のロック解除"
    m_Metadata:
      m_Items: []
  - m_Id: 22606455687757824
    m_Localized: "原材料の探索"
    m_Metadata:
      m_Items: []
  - m_Id: 22606619886370816
    m_Localized: "生産効率"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266010
    m_Localized: 森林調査 I
    m_Metadata:
      m_Items: []
  - m_Id: 864226267010
    m_Localized: 森林資源の調査により、伐採キャンプの設置上限を引き上げる。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266011
    m_Localized: 森林調査 II
    m_Metadata:
      m_Items: []
  - m_Id: 864226267011
    m_Localized: 木材評価を深化し、伐採キャンプの設置上限をさらに拡大する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266012
    m_Localized: 森林調査 III
    m_Metadata:
      m_Items: []
  - m_Id: 864226267012
    m_Localized: 水域・収量マッピングで適地を増やし、キャンプ用地を拡保する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266013
    m_Localized: 森林調査 IV
    m_Metadata:
      m_Items: []
  - m_Id: 864226267013
    m_Localized: 詳細な資源棚卸とアクセス路解析で、持続的採取の上限を広げる。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266014
    m_Localized: 森林調査 V
    m_Metadata:
      m_Items: []
  - m_Id: 864226267014
    m_Localized: 域内調査網を完成させ、伐採キャンプの許容規模を最大まで高める。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266015
    m_Localized: 鉄鉱調査 I
    m_Metadata:
      m_Items: []
  - m_Id: 864226267015
    m_Localized: 鉄鉱脈調査により、設置可能な鉄鉱山数の上限を引き上げる。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266016
    m_Localized: 鉄鉱調査 II
    m_Metadata:
      m_Items: []
  - m_Id: 864226267016
    m_Localized: 試料と地質モデルを強化し、鉄鉱山の設置上限をさらに拡大する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266017
    m_Localized: 鉄鉱調査 III
    m_Metadata:
      m_Items: []
  - m_Id: 864226267017
    m_Localized: 深部探査で鉄鉱採掘適地を広げ、設置上限を拡張する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266018
    m_Localized: 鉄鉱調査 IV
    m_Metadata:
      m_Items: []
  - m_Id: 864226267018
    m_Localized: 埋蔵量推定と物流計画を統合し、並行鉄鉱採掘規模を拡大する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266019
    m_Localized: 鉄鉱調査 V
    m_Metadata:
      m_Items: []
  - m_Id: 864226267019
    m_Localized: 鉱区全域の地質図を完成させ、運用可能な鉄鉱山数を最大化する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266020
    m_Localized: 石油探査 I
    m_Metadata:
      m_Items: []
  - m_Id: 864226267020
    m_Localized: 地表採取と物理探査で、油井（ポンプ）の設置上限を高める。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266021
    m_Localized: 石油探査 II
    m_Metadata:
      m_Items: []
  - m_Id: 864226267021
    m_Localized: 地下構造モデルの精緻化により、ポンプ配置の上限を拡大する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266022
    m_Localized: 石油探査 III
    m_Metadata:
      m_Items: []
  - m_Id: 864226267022
    m_Localized: 試掘と域内対比で油田評価を広げ、設置上限を引き上げる。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266023
    m_Localized: 石油探査 IV
    m_Metadata:
      m_Items: []
  - m_Id: 864226267023
    m_Localized: 貯留層特性の解析により、同時稼働可能なポンプ数の上限を増やす。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266024
    m_Localized: 石油探査 V
    m_Metadata:
      m_Items: []
  - m_Id: 864226267024
    m_Localized: 盆地規模の探査体制を完成させ、油井設置の上限を最大まで高める。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266025
    m_Localized: 金鉱調査 I
    m_Metadata:
      m_Items: []
  - m_Id: 864226267025
    m_Localized: 露頭・試料調査で金鉱山の設置上限を引き上げる。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266026
    m_Localized: 金鉱調査 II
    m_Metadata:
      m_Items: []
  - m_Id: 864226267026
    m_Localized: 試料解析と地質モデルの強化により、設置上限をさらに拡大する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266027
    m_Localized: 金鉱調査 III
    m_Metadata:
      m_Items: []
  - m_Id: 864226267027
    m_Localized: 深部ターゲット探査で金鉱山の同時稼働規模を拡大する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266028
    m_Localized: 金鉱調査 IV
    m_Metadata:
      m_Items: []
  - m_Id: 864226267028
    m_Localized: 埋蔵量推定と後勤解析により、並列採掘の上限を高める。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266029
    m_Localized: 金鉱山建設許可
    m_Metadata:
      m_Items: []
  - m_Id: 864226267029
    m_Localized: "専用金鉱山を解禁。金鉱石のみを採掘し製錬で純金にする。採掘研究の完了が前提。"
    m_Metadata:
      m_Items: []

  - m_Id: 864226266030
    m_Localized: 石炭調査 I
    m_Metadata:
      m_Items: []
  - m_Id: 864226267030
    m_Localized: 石炭層調査により、設置可能な石炭鉱山数の上限を引き上げる。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266031
    m_Localized: 石炭調査 II
    m_Metadata:
      m_Items: []
  - m_Id: 864226267031
    m_Localized: 層状モデルと試料分析を強化し、石炭鉱山の設置上限を拡大する。
    m_Metadata:
      m_Items: []
  - m_Id: 864226266032
    m_Localized: 石炭調査 III
    m_Metadata:
      m_Items: []
