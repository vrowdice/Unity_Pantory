  m_Name: Tutorial_ko
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: e00198e87a257ff41b02cc989c3a409a, type: 2}
  m_Metadata:
    m_Items:
    - rid: 2319839819189715043
  m_TableData:
  - m_Id: 11264212992
    m_Localized: "\uC548\uB155\uD558\uC138\uC694. \uD32C\uD1A0\uB9AC\uC5D0 \uC624\uC2E0
      \uAC83\uC744 \uD658\uC601\uD569\uB2C8\uB2E4. \uACF5\uC7A5\uC744 \uC9D3\uACE0
      \uBB3C\uB958\uB97C \uB3CC\uB9AC\uBA70 \uD68C\uC0AC\uB97C \uD0A4\uC6B0\uB294
      \uACBD\uC601 \uC2DC\uBBAC\uB808\uC774\uC158\uC774\uBA70, \uC218\uB144\uC5D0\uC11C
      \uC218\uC2ED \uB144 \uB2E8\uC704\uB85C \uC6B4\uC601\uC774 \uC774\uC5B4\uC9C0\uB294
      \uC804\uC81C\uC5D0 \uB9DE\uCDB0\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items:
      - rid: 2319839819189715043
  - m_Id: 438890283008
    m_Localized: "\uADF8\uB9AC\uB4DC\uC5D0 \uAC74\uBB3C\uACFC \uB3C4\uB85C\uB97C
      \uBC30\uCE58\uD574 \uC790\uC6D0\uC774 \uD750\uB974\uAC8C \uB9CC\uB4E4\uACE0,
      \uC800\uC7A5\uC18C\xB7\uBC1C\uC8FC\xB7\uC2DC\uC7A5\uC73C\uB85C \uD604\uAE08\uACFC
      \uC7AC\uACE0\uB97C \uB9DE\uCD94\uBA70, \uC9C1\uC6D0\uACFC \uC5F0\uAD6C\uB85C
      \uC0DD\uC0B0 \uB2A5\uB825\uC744 \uB113\uD600 \uAC00\uB294 \uAC8C\uC784\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 575934971904
    m_Localized: "\uBA3C\uC800 \uD654\uBA74 \uAD6C\uC131\uC744 \uC9DA\uC5B4 \uBD05\uB2C8\uB2E4.
      \uAC01 \uBA54\uC778 \uD328\uB110\uC758 (?) \uBC84\uD2BC\uC73C\uB85C \uC774
      \uB3C4\uC6C0\uB9D0\uC744 \uC5B8\uC81C\uB4E0 \uB2E4\uC2DC \uC5F4 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1678642659328
    m_Localized: "\uC67C\uCABD \uC704\uC758 \uD06C\uB808\uB527\xB7\uC5F0\uAD6C \uD3EC\uC778\uD2B8
      \uC601\uC5ED\uC744 \uB20C\uB7EC \uC0C1\uC138 \uD750\uB984\uC744 \uD655\uC778\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2291514359808
    m_Localized: "\uC0C1\uB2E8 \uC774 \uC601\uC5ED\uC5D0\uB294 \uC9C1\uC6D0 \uACE0\uC6A9
      \uD604\uD669, \uAC74\uBB3C\uC5D0 \uBC30\uCE58\uB41C \uC778\uC6D0, \uB9CC\uC871\uB3C4
      \uC694\uC57D\uC774 \uB098\uC635\uB2C8\uB2E4. \uB9E4\uB2C8\uC800\uAC00 \uBD80\uC871\uD558\uBA74
      \uB9CC\uC871\uB3C4\uC5D0 \uBD88\uC774\uC775\uC774 \uB4E4\uC5B4\uAC00\uACE0,
      \uADF8 \uACB0\uACFC \uC0DD\uC0B0 \uD6A8\uC728\uAE4C\uC9C0 \uC774\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2320476028928
    m_Localized: "\uC5EC\uAE30\uC5D0\uB294 \uAC8C\uC784 \uB0B4 \uB0A0\uC9DC\xB7\uC2DC\uAC01,
      \uD29C\uD1A0\uB9AC\uC5BC \uB2E4\uC2DC \uBCF4\uAE30, \uC124\uC815\uC73C\uB85C
      \uAC00\uB294 \uBC84\uD2BC\uC774 \uBAA8\uC5EC \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2777508364288
    m_Localized: "\uC800\uC7A5\uC18C, \uBC1C\uC8FC, \uC2DC\uC7A5, \uC9C1\uC6D0, \uC5F0\uAD6C,
      \uB274\uC2A4, \uC7AC\uBB34 \uD328\uB110\uB85C \uBC14\uB85C \uC774\uB3D9\uD558\uB294
      \uB2E8\uCD95 \uC544\uC774\uCF58\uC785\uB2C8\uB2E4. \uD0A4\uBCF4\uB4DC F1~F9\uB85C\uB3C4
      \uAC19\uC740 \uD328\uB110\uC744 \uC5F4 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 5943566155776
    m_Localized: "\uBB3C\uB958\uB294 \uACF5\uC7A5 \uC6B4\uC601\uC758 \uC911\uC2EC\uC785\uB2C8\uB2E4.
      \uD558\uC5ED\xB7\uC0DD\uC0B0\xB7\uC801\uC7AC\uB97C \uB3C4\uB85C\uB85C \uC787\uACE0
      \uC785\uCD9C\uB825 \uBC29\uD5A5\uC744 \uB9DE\uCDB0\uC57C \uC790\uC6D0\uC774
      \uB9C9\uD788\uC9C0 \uC54A\uACE0 \uD750\uB985\uB2C8\uB2E4. \uD55C \uAD6C\uAC04\uC774
      \uBA48\uCD94\uBA74 \uC0C1\uB958\xB7\uD558\uB958 \uC804\uCCB4\uAC00 \uAC19\uC774
      \uB290\uB824\uC9C0\uBBC0\uB85C \uBCD1\uBAA9\uC744 \uBE68\uB9AC \uC9DA\uB294
      \uAC83\uC774 \uC911\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7203816095744
    m_Localized: "\uAE30\uBCF8 \uD750\uB984\uC740 \uD558\uC5ED \u2192 \uB3C4\uB85C
      \u2192 \uC0DD\uC0B0 \uAC74\uBB3C \u2192 \uB3C4\uB85C \u2192 \uC801\uC7AC\uC785\uB2C8\uB2E4.
      \uD558\uC5ED\uC774 \uC6D0\uC790\uC7AC\uB97C \uB04C\uC5B4\uC624\uACE0, \uC0DD\uC0B0
      \uAC74\uBB3C\uC774 \uAC00\uACF5\uD558\uBA70, \uC801\uC7AC\uAC00 \uC644\uC81C\uD488\uC744
      \uC800\uC7A5\uC18C \uCABD\uC73C\uB85C \uBCF4\uB0C5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7579063697408
    m_Localized: "\uAC74\uBB3C \uBC84\uD2BC\uC740 \uC6A9\uB3C4\uBCC4\uB85C \uBB36\uC5EC
      \uC788\uC2B5\uB2C8\uB2E4. \uC720\uD1B5 \uCE74\uD14C\uACE0\uB9AC\uC5D0\uB294
      \uC77C\uBC18 \uB3C4\uB85C, \uC2A4\uD50C\uB9AC\uD130, \uD130\uB110\uC774 \uC788\uC2B5\uB2C8\uB2E4.
      \uC0DD\uC0B0 \uAC74\uBB3C\uC740 \uC5F0\uAD6C\uB85C \uD574\uAE08\uD558\uB294
      \uACBD\uC6B0\uAC00 \uB9CE\uC2B5\uB2C8\uB2E4. \uBE14\uB8E8\uD504\uB9B0\uD2B8
      \uD0ED\uC5D0\uC11C \uBC30\uCE58\uB97C \uC800\uC7A5\uD574 \uB098\uC911\uC5D0
      \uD55C \uBC88\uC5D0 \uAE54 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7894026567680
    m_Localized: "\uC774 \uBAA9\uB85D\uC5D0\uC11C \uAC74\uBB3C\xB7\uB3C4\uB85C\uB97C
      \uACE0\uB978 \uB4A4 \uADF8\uB9AC\uB4DC\uC5D0 \uBC30\uCE58\uD569\uB2C8\uB2E4.
      \uD68C\uC804\uC744 \uD655\uC778\uD558\uACE0 \uD074\uB9AD\uD574 \uB193\uC73C\uBA70,
      \uC785\uB825\uC744 \uAE38\uAC8C \uB204\uB974\uBA74 \uB3C4\uB85C\uB97C \uC5F0\uC18D\uC73C\uB85C
      \uAE54 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8131256401920
    m_Localized: "\uBA54\uC778 \uD654\uBA74\uC5D0\uC11C\uB3C4 \uC790\uC6D0 \uD750\uB984\uC744
      \uAC00\uB2A0\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uB77C\uC778\uC774 \uBA48\uCD94\uBA74
      \uC0C1\uB958 \uC7AC\uACE0\uC640 \uB3C4\uB85C \uBC29\uD5A5\xB7\uAC74\uBB3C \uBC29\uD5A5\xB7\uCD9C\uB825
      \uC5F0\uACB0\uC744 \uC21C\uC11C\uB300\uB85C \uBD05\uB2C8\uB2E4. \uC2DC\uC7A5
      \uAC00\uACA9\uC740 \uC218\uC694\uC640 \uB274\uC2A4 \uC774\uBCA4\uD2B8 \uB4F1\uC5D0
      \uB530\uB77C \uD754\uB4E4\uB9AC\uBBC0\uB85C, \uC800\uC7A5\uC18C \uC7AC\uACE0\uC640
      \uAC19\uC774 \uBCF4\uBA74 \uB9E4\uB9E4 \uD0C0\uC774\uBC0D\uC744 \uC7A1\uAE30
      \uC27D\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9056704413696
    m_Localized: "\uC88B\uC740 \uBB3C\uB958\uB294 \uC9E7\uC740 \uACBD\uB85C, \uBD84\uBA85\uD55C
      \uBC29\uD5A5, \uD55C \uC904\uC5D0 \uBAB0\uB9AC\uC9C0 \uC54A\uC740 \uCD9C\uB825\uC73C\uB85C
      \uC694\uC57D\uB429\uB2C8\uB2E4. \uACF5\uC7A5\uC744 \uB113\uD790\uC218\uB85D
      \uBCD1\uBAA9 \uC704\uCE58\uAC00 \uBC14\uB00C\uBBC0\uB85C \uC800\uC7A5\uC18C\xB7\uBC1C\uC8FC\xB7\uC2DC\uC7A5
      \uD328\uB110\uC744 \uC8FC\uAE30\uC801\uC73C\uB85C \uC5F4\uC5B4 \uC7AC\uACE0\uC640
      \uD604\uAE08\uC774 \uBC84\uD2F0\uB294\uC9C0 \uD655\uC778\uD558\uB294 \uC2B5\uAD00\uC774
      \uC7A5\uAE30 \uC6B4\uC601\uC5D0 \uB3C4\uC6C0\uC774 \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 11779361357824
    m_Localized: "\uC774 \uD328\uB110\uC5D0\uC11C \uC81C\uAC70 \uBAA8\uB4DC \uC804\uD658,
      \uAC74\uBB3C \uD68C\uC804, \uBC30\uCE58 \uC2DC \uC9C1\uC6D0 \uC790\uB3D9 \uBC30\uCE58\uB97C
      \uB2E4\uB8F9\uB2C8\uB2E4. \uC81C\uAC70 \uBAA8\uB4DC\uC5D0\uC11C \uAC74\uBB3C\uC744
      \uCE58\uC6B0\uBA74 \uC6CC\uCEE4\xB7\uD14C\uD06C\uB2C8\uC158 \uBC30\uCE58\uB3C4
      \uD568\uAED8 \uD480\uB9AC\uBBC0\uB85C, \uD070 \uAC1C\uD3B8 \uB4A4\uC5D0\uB294
      \uC9C1\uC6D0 \uD328\uB110\uC5D0\uC11C \uBC30\uCE58\uB97C \uB2E4\uC2DC \uB9DE\uCDA5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 12960301203456
    m_Localized: "\uC800\uC7A5\uC18C \uD328\uB110\uC785\uB2C8\uB2E4. \uC9C0\uAE08
      \uBCF4\uC720\uD55C \uC790\uC6D0 \uC218\uB7C9\uC774 \uD45C\uC2DC\uB429\uB2C8\uB2E4.
      \uC790\uC6D0\uC740 \uC6D0\uC790\uC7AC, \uAE08\uC18D, \uBB34\uAE30, \uC0DD\uD544\uD488,
      \uBA85\uD488, \uBD80\uD488, \uCC28\uB7C9 \uB4F1 \uC720\uD615\uC73C\uB85C \uB098\uB258\uBA70,
      \uAC01 \uC790\uC6D0\uC740 \uB808\uC2DC\uD53C\uC5D0 \uB530\uB77C \uB2E4\uB978
      \uC0DD\uC0B0 \uAC74\uBB3C\uC5D0\uC11C \uB9CC\uB4E4\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 13340426780672
    m_Localized: "\uC790\uC6D0\uB9C8\uB2E4 \uCE74\uD14C\uACE0\uB9AC\uAC00 \uC788\uC73C\uB2C8,
      \uC704\uCABD \uCE74\uD14C\uACE0\uB9AC \uBC84\uD2BC\uC73C\uB85C \uBAA9\uB85D\uC744
      \uC881\uD600 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 17836750028800
    m_Localized: "\uBC1C\uC8FC \uD328\uB110\uC785\uB2C8\uB2E4. \uACC4\uC57D\uC744
      \uC218\uB77D\uD558\uACE0 \uAE30\uD55C \uC548\uC5D0 \uC790\uC6D0\uC744 \uB0A9\uD488\uD574
      \uD06C\uB808\uB527\uACFC \uC2DC\uC7A5 \uD3C9\uD310\uC744 \uC62C\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 17928651423744
    m_Localized: "\uC2DC\uC7A5\xB7\uAE30\uC5C5\xB7\uC815\uBD80 \uBC84\uD2BC\uC73C\uB85C
      \uBC1C\uC8FC \uC720\uD615\uC744 \uAC78\uB7EC \uB0C5\uB2C8\uB2E4. \uBCF4\uD1B5
      \uADF8 \uC21C\uC11C\uB85C \uADDC\uBAA8\uAC00 \uCEE4\uC9C0\uBA70, \uD68C\uC0AC
      \uC790\uC0B0(Wealth)\uC5D0 \uB530\uB77C \uC694\uAD6C\uB7C9\uB3C4 \uB2EC\uB77C\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 18539786682368
    m_Localized: "\uC774 \uC2A4\uC704\uCE58\uB97C \uCF1C\uBA74 \uC9C0\uAE08 \uC9C4\uD589
      \uC911\uC778 \uC218\uB77D \uBC1C\uC8FC\uB9CC \uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 18834268766208
    m_Localized: "\uC67C\uCABD\uC5D0\uC11C \uAC70\uB798\uCC98\uB97C \uACE0\uB974\uBA74
      \uC624\uB978\uCABD\uC5D0 \uADF8 \uAC70\uB798\uCC98\uC758 \uBC1C\uC8FC \uBAA9\uB85D\uC774
      \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 19061579071488
    m_Localized: "\uC0C8 \uACC4\uC57D\uC774 \uC5EC\uAE30\uC5D0 \uC313\uC785\uB2C8\uB2E4.
      \uD074\uB9AD\uD574 \uC218\uB77D\uD55C \uB4A4, \uAE30\uD55C \uC548\uC5D0 \uC694\uAD6C
      \uC790\uC6D0\uC744 \uB0A9\uD488\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 19716532224000
    m_Localized: "\uC2DC\uC7A5 \uD328\uB110\uC785\uB2C8\uB2E4. \uC790\uC6D0 \uAC70\uB798\uC640
      \uACBD\uC7C1\uC0AC \uC815\uBCF4\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 22018345287680
    m_Localized: "\uC774 \uBC84\uD2BC\uC73C\uB85C \uC790\uC6D0 \uBCF4\uAE30\uC640
      \uAC70\uB798\uC790(\uACBD\uC7C1\uC0AC) \uBCF4\uAE30\uB97C \uC804\uD658\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 22020337582080
    m_Localized: "\uC790\uC6D0 \uBCF4\uAE30\uC785\uB2C8\uB2E4. \uD604\uC7AC \uC790\uC6D0\uC758
      \uAD6C\uB9E4\xB7\uD310\uB9E4\uB7C9\uC744 \uC5EC\uAE30\uC11C \uC870\uC808\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24215317528576
    m_Localized: "\uC790\uC6D0 \uC815\uBCF4\uB294 \uC5EC\uAE30\uC5D0 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24483870425088
    m_Localized: "\uC790\uC6D0 \uAC00\uACA9 \uCD94\uC774\uAC00 \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24698149027840
    m_Localized: "\uAC70\uB798\uC790(\uACBD\uC7C1\uC0AC) \uBCF4\uAE30\uC785\uB2C8\uB2E4.
      \uAC01 \uAC70\uB798\uC790 \uC815\uBCF4\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 36510642880512
    m_Localized: "\uC9C1\uC6D0\uC744 \uAD00\uB9AC\uD558\uB294 \uD328\uB110\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 36904429305856
    m_Localized: "\uD604\uC7AC \uAD00\uB9AC \uB2A5\uB825\uC774 \uD45C\uC2DC\uB429\uB2C8\uB2E4.
      \uC9C1\uC6D0 \uC218\uC5D0 \uBE44\uD574 \uC77C\uC815 \uC218\uC758 \uB9E4\uB2C8\uC800\uAC00
      \uD544\uC694\uD558\uBA70, \uBD80\uC871\uD558\uBA74 \uB9CC\uC871\uB3C4\uAC00
      \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 37440536854528
    m_Localized: "\uC9C1\uC6D0 \uB9CC\uC871\uB3C4\uB294 \uC5EC\uB7EC \uC694\uC778\uC5D0
      \uB530\uB77C \uB2EC\uB77C\uC9D1\uB2C8\uB2E4. \uC5B4\uB5A4 \uC601\uD5A5\uC778\uC9C0\uB294
      \uC5EC\uAE30\uC11C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 37828904239104
    m_Localized: "\uC9C1\uC6D0 \uD6A8\uC728\uC740 \uB9CC\uC871\uB3C4\uC5D0 \uB530\uB77C
      \uB2EC\uB77C\uC9C0\uBA70, \uADF8 \uD6A8\uC728\uC774 \uAC74\uBB3C \uC791\uC5C5
      \uC18D\uB3C4\uC640 \uC0DD\uC0B0 \uCC98\uB9AC\uB7C9\uC5D0 \uC601\uD5A5\uC744
      \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 38302378246144
    m_Localized: "\uB9CC\uC871\uB3C4\uB97C \uC62C\uB9AC\uB294 \uAC00\uC7A5 \uC26C\uC6B4
      \uBC29\uBC95\uC740 \uC784\uAE08 \uC778\uC0C1\uC785\uB2C8\uB2E4. \uB0AE\uCD94\uBA74
      \uB9CC\uC871\uB3C4\uAC00 \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39086448852992
    m_Localized: "\uC9C1\uC6D0\uC740 \uB124 \uC5ED\uD560\uC785\uB2C8\uB2E4. \uC6CC\uCEE4\xB7\uD14C\uD06C\uB2C8\uC158\uC740
      \uAC74\uBB3C\uC5D0 \uBC30\uCE58\uD558\uACE0, \uC5F0\uAD6C\uC6D0\uC740 RP, \uB9E4\uB2C8\uC800\uB294
      \uAD00\uB9AC \uBE44\uC728\uC744 \uB9DE\uCDB0 \uB9CC\uC871\uB3C4 \uD558\uB77D\uC744
      \uB9C9\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39688935456768
    m_Localized: "\uC5EC\uAE30\uC11C \uC9C1\uC6D0 \uACE0\uC6A9\xB7\uD574\uACE0\uB97C
      \uACB0\uC815\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uACE0\uC6A9\xB7\uD574\uACE0\uC5D0\uB294
      \uD06C\uB808\uB527\uC774 \uB4E4\uACE0, \uD574\uACE0\uD558\uBA74 \uB9CC\uC871\uB3C4\uAC00
      \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2561770013474816
    m_Localized: "\uC5F0\uAD6C \uD328\uB110\uC785\uB2C8\uB2E4. \uAC74\uBB3C \uD574\uAE08\uACFC
      \uC0DD\uC0B0\uC131 \uD5A5\uC0C1\uC774 \uAC00\uB2A5\uD574\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562082698838016
    m_Localized: "\uC5F0\uAD6C \uD3EC\uC778\uD2B8(RP)\uC640 \uD558\uB8E8 \uD68D\uB4DD\uB7C9\uC774
      \uC5EC\uAE30 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562316594200576
    m_Localized: "\uC5F0\uAD6C\uC6D0 \uC218\uC640 \uC801\uC6A9 \uC911\uC778 \uD6A8\uACFC\uB97C
      \uBCFC \uC218 \uC788\uB294 \uD328\uB110\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562738453102592
    m_Localized: "\uC5F0\uAD6C \uD2B8\uB9AC\uC785\uB2C8\uB2E4. \uC644\uB8CC\uD55C
      \uC5F0\uAD6C\uB294 \uC0C9\uC73C\uB85C \uD45C\uC2DC\uB418\uACE0, \uC774\uC5B4\uC9C0\uB294
      \uC5F0\uAD6C\uAC00 \uC21C\uC11C\uB300\uB85C \uD574\uAE08\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2563160425250816
    m_Localized: "\uC7AC\uBB34 \uD328\uB110\uC785\uB2C8\uB2E4. \uD68C\uC0AC \uC131\uC7A5
      \uCD94\uC774\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2564533472608256
    m_Localized: "\uD604\uC7AC \uC6D4\uAC04 \uC131\uC7A5\uB960\uC744 \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2565297930649600
    m_Localized: "\uD604\uC7AC \uC6D4\uAC04 \uC774\uC775\uC744 \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2566859943985152
    m_Localized: "\uD604\uC7AC \uAE30\uC5C5 \uAC00\uCE58\uB97C \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2566981499109376
    m_Localized: "\uD604\uC7AC \uD06C\uB808\uB527\uC744 \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000000
    m_Localized: "\uB178\uC870 \uC870\uC9C1\uD654 \uCC55\uD130\uB97C \uAD00\uB9AC\uD558\uB294
      \uD328\uB110\uC785\uB2C8\uB2E4. \uC9C4\uD589 \uC911\uC5D0\uB294 \uC885\uD569
      \uB9CC\uC871\uB3C4\uC5D0 \uB530\uB77C \uB9E4\uC77C \uACB0\uD569\uB3C4\uAC00
      \uC624\uB974\uAC70\uB098 \uB5A8\uC5B4\uC9C0\uBA70, \uB178\uC870 \uC694\uAD6C\uB97C
      \uCDA9\uC871\uD558\uBA74 \uACB0\uD569\uB3C4 \uBCF4\uC0C1\uC744 \uBC1B\uC744
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000001
    m_Localized: "\uC774\uBCA4\uD2B8 \uC544\uC774\uCF58\uACFC \uC22B\uC790\uB294
      \uCC55\uD130 \uB0A8\uC740 \uC77C\uC218\uC785\uB2C8\uB2E4. 0\uC774 \uB418\uBA74
      \uB178\uC870 \uC774\uBCA4\uD2B8\uAC00 \uC885\uB8CC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000002
    m_Localized: "\uAC00\uC911 \uD3C9\uADE0 \uB9CC\uC871\uB3C4\uC5D0 \uB530\uB978
      \uB0B4\uC77C\uC758 \uC77C\uC77C \uACB0\uD569\uB3C4 \uBCC0\uD654\uB97C \uBBF8\uB9AC
      \uBCF4\uC5EC \uC90D\uB2C8\uB2E4. \uC67C\uCABD \uB9C9\uB300\uB294 \uAE30\uC900
      \uC774\uC0C1\uC77C \uB54C \uC67C\uCABD\u2192\uC624\uB978\uCABD\uC73C\uB85C
      \uC99D\uAC00\uB7C9\uC744, \uC624\uB978\uCABD \uB9C9\uB300\uB294 \uAE30\uC900
      \uBBF8\uB9CC\uC77C \uB54C \uC624\uB978\uCABD\u2192\uC67C\uCABD\uC73C\uB85C
      \uAC10\uC18C\uB7C9\uC744 \uD45C\uC2DC\uD569\uB2C8\uB2E4. \uC22B\uC790\uB294
      \uD558\uB8E8\uB2F9 \uBCC0\uD654\uC728(%)\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000003
    m_Localized: "\uACB0\uD569\uB3C4\uB294 \uC774 \uC774\uBCA4\uD2B8\uC758 \uD575\uC2EC
      \uC9C0\uD45C\uB85C 0~100%\uC785\uB2C8\uB2E4. \uC704 \uB9CC\uC871\uB3C4 \uBC14\uC5D0
      \uB530\uB77C \uB9E4\uC77C \uC790\uB3D9\uC73C\uB85C \uBCC0\uD558\uBA70, 100%\uC5D0
      \uB3C4\uB2EC\uD558\uBA74 \uCC55\uD130\uB97C \uC644\uB8CC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000004
    m_Localized: "\uC9C1\uC885\uBCC4 \uB9CC\uC871\uB3C4\uAC00 \uD45C\uC2DC\uB429\uB2C8\uB2E4.
      \uC9C1\uC6D0 \uD328\uB110\uC758 \uAE09\uC5EC \uC870\uC815, \uB300\uB7C9 \uD574\uACE0
      \uC790\uC81C, \uB178\uC870 \uC694\uAD6C \uC644\uB8CC\uAC00 \uC77C\uC77C \uBCC0\uD654
      \uB9C9\uB300\uC640 \uACB0\uD569\uB3C4\uB97C \uC6C0\uC9C1\uC774\uB294 \uC8FC\uC694
      \uBC29\uBC95\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000005
    m_Localized: "\uD65C\uC131 \uB178\uC870 \uC694\uAD6C \uBAA9\uB85D\uC785\uB2C8\uB2E4.
      \uC694\uAD6C\uB9C8\uB2E4 \uD06C\uB808\uB527\xB7\uC790\uC6D0\xB7\uC815\uCC45
      \uC911 \uD558\uB098\uC758 \uC870\uAC74\uACFC \uB9C8\uAC10 \uC77C\uC218\uAC00
      \uC788\uC2B5\uB2C8\uB2E4. \uC870\uAC74\uC744 \uCDA9\uC871\uD558\uBA74 \uD589\uC774
      \uAC15\uC870\uB418\uBA70, \uD0ED\uD558\uBA74 \uC644\uB8CC \uCC98\uB9AC \uD6C4
      \uACB0\uD569\uB3C4 \uBCF4\uC0C1\uC744 \uBC1B\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000000
    m_Localized: "\uC815\uCC45 \uD328\uB110\uC785\uB2C8\uB2E4. \uC9C1\uC7A5 \uADDC\uCE59\uC744
      \uCF1C\uACE0 \uB044\uBA70 \uC0DD\uC0B0\xB7\uBE44\uC6A9\xB7\uB9CC\uC871\uB3C4\uC5D0
      \uC9C0\uC18D \uD6A8\uACFC\uB97C \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000001
    m_Localized: "\uAC01 \uC815\uCC45\uC744 \uCF1C\uAC70\uB098 \uB04C \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uD06C\uB808\uB527\xB7RP\uAC00 \uB4E4\uAC70\uB098 \uBA87 \uAC1C\uC6D4\uB9CC
      \uC720\uC9C0\uB418\uB294 \uC815\uCC45\uB3C4 \uC788\uC73C\uB2C8 \uB0B4\uC6A9\uC744
      \uD655\uC778\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000002
    m_Localized: "\uD65C\uC131 \uC815\uCC45\uACFC \uD6A8\uACFC\uAC00 \uC5EC\uAE30
      \uC694\uC57D\uB429\uB2C8\uB2E4. \uD604\uC7AC \uACF5\uC7A5\uC5D0 \uC801\uC6A9
      \uC911\uC778 \uBCF4\uB108\uC2A4\xB7\uD398\uB110\uD2F0\uB97C \uD55C\uB208\uC5D0
      \uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000000
    m_Localized: "\uB274\uC2A4 \uD328\uB110\uC785\uB2C8\uB2E4. \uC2DC\uC7A5 \uBCC0\uD654,
      \uBA54\uC778 \uC774\uBCA4\uD2B8 \uB4F1 \uC9C4\uD589\uC5D0 \uB9DE\uB294 \uD5E4\uB4DC\uB77C\uC778\uC774
      \uC313\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000001
    m_Localized: "\uC5EC\uAE30\uC11C \uAE30\uC0AC \uBAA9\uB85D\uC744 \uC2A4\uD06C\uB864\uD569\uB2C8\uB2E4.
      \uC870\uAC74\uC774 \uB9DE\uC73C\uBA74 \uC0C8 \uAE30\uC0AC\uAC00 \uCD94\uAC00\uB418\uACE0,
      \uAE30\uD55C\uC774 \uC9C0\uB098\uBA74 \uC0AC\uB77C\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000002
    m_Localized: "\uC81C\uBAA9\uC744 \uC5F4\uBA74 \uBCF8\uBB38\uC744 \uC77D\uC744
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uAC00\uACA9\xB7\uB178\uC870\xB7\uC5F0\uAD6C
      \uD78C\uD2B8\uAC00 \uB9CE\uC73C\uB2C8 \uD070 \uBCC0\uD654 \uD6C4\uC5D0 \uB2E4\uC2DC
      \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds:
    - rid: 2319839819189715043
      type: {class: SmartFormatTag, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_Entries: 
        m_SharedEntries:
