  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: NewsDescription_ja
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ja
  m_SharedData: {fileID: 11400000, guid: 50732f9fa28f1df438110b6c9d789e65, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 7000000000001
    m_Localized: 国際紛争の激化により、世界的な軍拡競争が勃発しました。小型火器、重火器、弾薬、戦車の需要が急増しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000002
    m_Localized: 技術革新と政府の補助金により、自動車産業が好況を迎えています。自動車、エンジン、鉄鋼、アルミニウム、石油の価格高騰が予想されます。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000003
    m_Localized: 革新的な航空エンジン設計が市場を活性化させました。飛行機、アルミニウム、エンジン、電子部品の需要が急増しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000004
    m_Localized: 世界的なサプライチェーンの混乱により半導体生産が停止しました。電子部品、精密工具、機械部品の価格が急速に上昇しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000005
    m_Localized: 大規模な世界的ショッピングイベントにより倉庫が空になりました。電子部品、衣類（一般・高級）、家具の需要が過去最高を記録しました。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000006
    m_Localized: 経済の不安定化により、投資家が安全資産に殺到しています。金鉱石と純金の価値が急上昇しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000007
    m_Localized: 急速な都市化により建設ラッシュが起きています。鉄鋼、家具（一般・高級）、高級木材の価格が急騰しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000008
    m_Localized: 新しい奢侈禁止令により、贅沢品の販売が厳しく禁じられました。高級衣類、高級家具、純金の市場が暴落しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000009
    m_Localized: 主要鉱山での壊滅的な事故により採掘が停止しました。石炭、鉄鉱石、アルミニウム鉱石、金鉱石の不足が予想されます。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000010
    m_Localized: 産油地域での地政学的紛争により生産量が激減しました。石油価格が前例のないレベルまで高騰しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000011
    m_Localized: 歴史的な平和条約により、世界的な非武装化が進んでいます。弾薬、戦車、飛行機の価格下落を招いています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000012
    m_Localized: 輸入金属への重課税により貿易が混乱しています。国内の鉄鋼および鉄鉱石価格が急騰しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000013
    m_Localized: 繊維産業全体での大規模なストライキにより生産が麻痺しています。織物、基本衣類、高級衣類が不足しています。
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
