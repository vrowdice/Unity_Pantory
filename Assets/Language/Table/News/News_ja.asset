  - m_Id: 7000000001001
    m_Localized: "\u56FD\u969B\u7D1B\u4E89\u306E\u6FC0\u5316\u306B\u3088\u308A\u3001\u4E16\u754C\u7684\u306A\u8ECD\u62E1\u7AF6\u4E89\u304C\u52C3\u767A\u3057\u307E\u3057\u305F\u3002\u5C0F\u578B\u706B\u5668\u3001\u91CD\u706B\u5668\u3001\u5F3E\u85AC\u3001\u6226\u8ECA\u306E\u9700\u8981\u304C\u6025\u5897\u3057\u3066\u3044\u307E\u3059\u3002"
