  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Tutorial_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: e00198e87a257ff41b02cc989c3a409a, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 2578300000000004
    m_Localized: Materials in input/output buffers. Tap an icon to return stock to
      inventory.
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000006
    m_Localized: Tap this button to change the output resource. Buffer materials
      return to inventory first.
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000003
    m_Localized: Shows recipe inputs and outputs.
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000002
    m_Localized: Build cost, daily maintenance, required staff, and assignment sliders
      are shown here.
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000001
    m_Localized: The building name is shown here. The indicator below shows whether
      technicians are required.
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000000
    m_Localized: Manage staff, recipes, buffers, and production for the selected
      building.
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000002
    m_Localized: Open a headline to read the full article.
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000001
    m_Localized: Scroll active stories here. New articles appear and old ones expire.
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000000
    m_Localized: Headlines on market shifts and main events appear here.
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000002
    m_Localized: Active policies and their effects are summarized here.
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000001
    m_Localized: Each policy can be switched on or off. Some cost credits or RP.
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000005
    m_Localized: Active union requests with one requirement and a deadline. Tap to
      complete when met.
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000004
    m_Localized: Role satisfaction is shown here. Pay raises and completing requests
      help most.
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000000
    m_Localized: Toggle workplace rules with ongoing effects on production and satisfaction.
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000003
    m_Localized: "Union Cohesion (0\u2013100%) shifts daily. Reaching 100% completes
      the chapter."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000002
    m_Localized: Previews tomorrow's daily cohesion change from workforce satisfaction.
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000001
    m_Localized: Shows days remaining in this chapter. At zero the union phase ends.
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000000
    m_Localized: Tracks the Labor Union chapter. Satisfaction shifts daily cohesion;
      fulfilling requests adds more.
    m_Metadata:
      m_Items: []
  - m_Id: 2566981499109376
    m_Localized: Shows your current credits in a graph.
    m_Metadata:
      m_Items: []
  - m_Id: 2566859943985152
    m_Localized: Shows your current company value in a graph.
    m_Metadata:
      m_Items: []
  - m_Id: 2565297930649600
    m_Localized: Shows your current monthly profit.
    m_Metadata:
      m_Items: []
  - m_Id: 2564533472608256
    m_Localized: Shows your current monthly growth rate.
    m_Metadata:
      m_Items: []
  - m_Id: 2563160425250816
    m_Localized: View your company's growth over time here.
    m_Metadata:
      m_Items: []
  - m_Id: 2562738453102592
    m_Localized: Completed research is tinted; linked projects unlock in order.
    m_Metadata:
      m_Items: []
  - m_Id: 2562316594200576
    m_Localized: See researcher count and active effects here.
    m_Metadata:
      m_Items: []
  - m_Id: 2562082698838016
    m_Localized: Research Points (RP) and daily gain are shown here.
    m_Metadata:
      m_Items: []
  - m_Id: 2561770013474816
    m_Localized: Unlock buildings and boost productivity here.
    m_Metadata:
      m_Items: []
  - m_Id: 39688935456768
    m_Localized: Hire or fire employees here. Both actions cost credits.
    m_Metadata:
      m_Items: []
  - m_Id: 38302378246144
    m_Localized: Raising pay is the easiest way to improve satisfaction.
    m_Metadata:
      m_Items: []
  - m_Id: 37440536854528
    m_Localized: See what is affecting employee satisfaction here.
    m_Metadata:
      m_Items: []
  - m_Id: 36904429305856
    m_Localized: Shows management capacity. Short on managers and satisfaction will
      drop.
    m_Metadata:
      m_Items: []
  - m_Id: 39086448852992
    m_Localized: Workers and Technicians staff buildings, Researchers generate RP,
      and Managers prevent satisfaction penalties.
    m_Metadata:
      m_Items: []
  - m_Id: 36510642880512
    m_Localized: This is the panel where you can manage your employees.
    m_Metadata:
      m_Items: []
  - m_Id: 37828904239104
    m_Localized: Efficiency depends on satisfaction and affects production speed.
    m_Metadata:
      m_Items: []
  - m_Id: 24812468024680
    m_Localized: Making money through the market is key. Watch prices and trade at
      the right time.
    m_Metadata:
      m_Items: []
  - m_Id: 24698149027840
    m_Localized: View information about each trader (competitor) here.
    m_Metadata:
      m_Items: []
  - m_Id: 24483870425088
    m_Localized: Resource price history is shown here as a graph.
    m_Metadata:
      m_Items: []
  - m_Id: 24215317528576
    m_Localized: Resource information is displayed here.
    m_Metadata:
      m_Items: []
  - m_Id: 22020337582080
    m_Localized: Adjust your current resource purchase and sale volume here.
    m_Metadata:
      m_Items: []
  - m_Id: 22018345287680
    m_Localized: Switch between the resource view and the trader (competitor) view
      here.
    m_Metadata:
      m_Items: []
  - m_Id: 19716532224000
    m_Localized: This is the Market panel. Buy and sell resources and view competitor
      info.
    m_Metadata:
      m_Items: []
  - m_Id: 19061579071488
    m_Localized: New contracts appear here. Click one to accept it, then deliver
      before time runs out.
    m_Metadata:
      m_Items: []
  - m_Id: 18834268766208
    m_Localized: Pick a client in this list to see their available contracts on the
      right.
    m_Metadata:
      m_Items: []
  - m_Id: 18539786682368
    m_Localized: Toggle this switch to show only accepted orders you are currently
      fulfilling.
    m_Metadata:
      m_Items: []
  - m_Id: 17928651423744
    m_Localized: Filter by Market, Company, or Government. Orders usually grow larger
      in that order.
    m_Metadata:
      m_Items: []
  - m_Id: 17836750028800
    m_Localized: This is the Orders panel. Accept a contract, then deliver resources
      before the deadline.
    m_Metadata:
      m_Items: []
  - m_Id: 13340426780672
    m_Localized: Every resource belongs to a category; use the filters here to narrow
      the list.
    m_Metadata:
      m_Items: []
  - m_Id: 12960301203456
    m_Localized: This is the storage panel. Your current resource inventory is shown
      here.
    m_Metadata:
      m_Items: []
  - m_Id: 9056704413697
    m_Localized: Press the Goals button to find your next steps! Good luck!
    m_Metadata:
      m_Items: []
  - m_Id: 9056704413696
    m_Localized: Use splitters and tunnels to keep lines stable as your factory grows.
    m_Metadata:
      m_Items: []
  - m_Id: 8131256401920
    m_Localized: Current resource counts are shown here.
    m_Metadata:
      m_Items: []
  - m_Id: 11779361357824
    m_Localized: Remove mode and auto-assignment switches are here.
    m_Metadata:
      m_Items: []
  - m_Id: 7894026567680
    m_Localized: Select a building or road here to place it on the grid.
    m_Metadata:
      m_Items: []
  - m_Id: 7579063697408
    m_Localized: Building buttons are grouped by category.
    m_Metadata:
      m_Items: []
  - m_Id: 7203816095744
    m_Localized: Save building layouts in the Blueprint tab and place them again
      later.
    m_Metadata:
      m_Items: []
  - m_Id: 5943566155776
    m_Localized: Use the building buttons below to construct buildings on the grid.
    m_Metadata:
      m_Items: []
  - m_Id: 2777508364288
    m_Localized: "Shortcuts to Storage, Orders, Market, Staff, Research, News, and
      Finance. F1\u2013F9 works too."
    m_Metadata:
      m_Items: []
  - m_Id: 2320476028928
    m_Localized: In-game date, time, tutorial, and settings buttons are here.
    m_Metadata:
      m_Items: []
  - m_Id: 2291514359808
    m_Localized: Employee count, assignments, and satisfaction are shown here.
    m_Metadata:
      m_Items: []
  - m_Id: 1678642659328
    m_Localized: Credits and Research Points are shown at the top left.
    m_Metadata:
      m_Items: []
  - m_Id: 575934971904
    m_Localized: Each main panel has a (?) button to reopen this help.
    m_Metadata:
      m_Items: []
  - m_Id: 438890283008
    m_Localized: Pantory is a factory management simulation game.
    m_Metadata:
      m_Items: []
  - m_Id: 11264212992
    m_Localized: Hello! Welcome to the main game of Pantory!
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000005
    m_Localized: Production progress and staff efficiency for the current batch.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
