  m_TableData:
  - m_Id: 864226266001
    m_Localized: "\uBD80\uD488 \uC81C\uC870"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266002
    m_Localized: "\uCC44\uAD74"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266003
    m_Localized: "\uD654\uD559 \uACF5\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266004
    m_Localized: "\uC911\uACF5\uC5C5"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266005
    m_Localized: "\uC11D\uC720 \uCC44\uAD74"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266006
    m_Localized: "\uAE08\uC18D \uC81C\uB828"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266007
    m_Localized: "\uC5D4\uC9C4 \uC81C\uC870"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266008
    m_Localized: "\uAD70\uC0AC \uC0DD\uC0B0"
    m_Metadata:
      m_Items: []
  - m_Id: 864226266009
    m_Localized: "\uCC28\uB7C9 \uC870\uB9BD"
    m_Metadata:
      m_Items: []
  - m_Id: 10606215174701056
    m_Localized: "\uACF5\uC7A5 \uAE30\uBCF8"
    m_Metadata:
      m_Items: []
  - m_Id: 864226267001
    m_Localized: "\uBD80\uD488 \uACF5\uC7A5 \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4.
      \uC815\uC81C\uB41C \uAE08\uC18D \uC8FC\uAD34\uB85C \uAE30\uACC4 \uBD80\uD488,
      \uC804\uC790 \uBD80\uD488, \uC815\uBC00 \uACF5\uAD6C \uB4F1\uC744 \uC0DD\uC0B0\uD560
      \uC218 \uC788\uB2E4. \uC911\uBC18 \uC0DD\uC0B0 \uCCB4\uC778\uC758 \uC2DC\uC791\uC810\uC774
      \uB418\uC5B4 \uACE0\uAE09 \uAC74\uBB3C \uBC0F \uCC28\uB7C9 \uC0DD\uC0B0\uC5D0
      \uD544\uC218\uC801\uC778 \uC7AC\uB8CC\uB97C \uACF5\uAE09\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226267002
    m_Localized: "\uAD11\uC0B0 \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4. \uCCA0\uAD11\uC11D,
      \uC11D\uD0C4, \uAD6C\uB9AC, \uAE08, \uC54C\uB8E8\uBBF8\uB284 \uB4F1 \uD544\uC218
      \uAD11\uBB3C\uC758 \uC790\uAE09\uC744 \uAC00\uB2A5\uD558\uAC8C \uD55C\uB2E4.
      \uAC74\uC124\xB7\uC720\uC9C0 \uBE44\uC6A9\uC740 \uB192\uC9C0\uB9CC \uC0B0\uC5C5\uC758
      \uAE30\uBC18\uC774 \uB418\uB294 \uC6D0\uC790\uC7AC\uB97C \uACF5\uAE09\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226267003
    m_Localized: "\uD654\uD559 \uACF5\uC7A5 \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4.
      \uC6D0\uC720\uB97C \uD569\uC131 \uC12C\uC720\uC640 \uD654\uD559 \uC81C\uD488\uC73C\uB85C
      \uAC00\uACF5\uD55C\uB2E4. \uC81C\uC7AC\uC18C\uC758 \uB300\uC548\uC774\uC790
      \uBCF4\uC644\uC73C\uB85C, \uC11D\uC720 \uAE30\uBC18 \uC9C1\uBB3C \uC0DD\uC0B0\uC73C\uB85C
      \uBAA9\uC7AC \uC758\uC874\uC744 \uC904\uC778\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226267004
    m_Localized: "\uC911\uACF5\uC5C5 \uACF5\uC7A5 \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4.
      \uACE0\uAE09 \uAC15\uC7AC\uC640 \uCD5C\uC2E0 \uBD80\uD488\uC73C\uB85C \uC815\uBC00
      \uACF5\uAD6C\uC640 \uACE0\uAE09 \uC81C\uD488\uC744 \uC0DD\uC0B0\uD55C\uB2E4.
      \uC0C1\uB2F9\uD55C \uD22C\uC790\uAC00 \uD544\uC694\uD558\uC9C0\uB9CC \uACE0\uAE09
      \uC2DC\uC7A5\uC744 \uACA8\uB0E5\uD574 \uC774\uC775\uB960\uC744 \uADF9\uB300\uD654\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226267005
    m_Localized: "\uC720\uC815 \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4. \uC9C0\uD558\uC758
      \uC6D0\uC720\uB97C \uCC44\uAD74\uD55C\uB2E4. \uC804\uB7B5 \uC790\uC6D0 \uC790\uAE09\uC758
      \uC2DC\uC791\uC810\uC774\uB2E4. \uC720\uC9C0 \uBE44\uC6A9\uC774 \uB9E4\uC6B0
      \uB192\uC9C0\uB9CC \uD654\uD559 \uC0B0\uC5C5\uACFC \uC5F0\uB8CC \uC0DD\uC0B0\uC758
      \uAE30\uBC18\uC744 \uC774\uB8EC\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226267006
    m_Localized: "\uC81C\uB828\uC18C \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4.
      \uAD11\uC0B0\uC5D0\uC11C \uCC44\uAD74\uD55C \uC6D0\uAD11\uC11D\uC744 \uC815\uC81C
      \uAE08\uC18D \uC8FC\uAD34\uB85C \uAC00\uACF5\uD55C\uB2E4. \uCCA0\xB7\uAD6C\uB9AC\xB7\uC54C\uB8E8\uBBF8\uB284
      \uC8FC\uAD34 \uB4F1\uC744 \uC0DD\uC0B0\uD574 \uAE08\uC18D \uC0B0\uC5C5\uC5D0
      \uD544\uC218\uC801\uC778 \uC911\uAC04 \uC7AC\uB8CC\uB97C \uACF5\uAE09\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226267007
    m_Localized: "\uC5D4\uC9C4 \uACF5\uC7A5 \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4.
      \uAE30\uACC4 \uBD80\uD488, \uC804\uC790 \uBD80\uD488, \uAC15 \uC8FC\uAD34\uB97C
      \uC870\uD569\uD574 \uACE0\uC131\uB2A5 \uB0B4\uC5F0\uAE30\uAD00\uC744 \uC0DD\uC0B0\uD55C\uB2E4.
      \uCC28\uB7C9 \uC0DD\uC0B0\uC744 \uC704\uD55C \uC120\uD589 \uD22C\uC790\uC774\uBA70,
      \uACE0\uBD80\uAC00\uAC00\uCE58 \uC911\uAC04 \uC7AC\uB8CC \uC0DD\uC0B0\uC744
      \uC2DC\uC791\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226267008
    m_Localized: "\uAD70\uC0AC \uACF5\uC7A5 \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4.
      \uAC15 \uC8FC\uAD34\uC640 \uAE30\uACC4 \uBD80\uD488\uC73C\uB85C \uC18C\uD654\uAE30,
      \uC911\uD654\uAE30, \uD0C4\uC57D \uB4F1\uC744 \uC0DD\uC0B0\uD55C\uB2E4. \uAD6D\uAC00\uC758
      \uC804\uB7B5 \uC790\uC6D0\uC73C\uB85C, \uC804\uC7C1 \uC900\uBE44\uC640 \uBB34\uAE30
      \uC2DC\uC7A5 \uC7A5\uC545\uC5D0 \uD544\uC218\uC801\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226267009
    m_Localized: "\uCC28\uB7C9 \uC870\uB9BD \uACF5\uC7A5 \uAC74\uC124\uC744 \uD574\uAE08\uD55C\uB2E4.
      \uC5D4\uC9C4, \uBD80\uD488, \uC804\uC790 \uBD80\uD488 \uB4F1\uC744 \uC870\uD569\uD574
      \uC790\uB3D9\uCC28, \uC804\uD22C\uAE30, \uC804\uCC28 \uB4F1 \uCD5C\uACE0 \uBD80\uAC00\uAC00\uCE58
      \uCD5C\uC885 \uC81C\uD488\uC744 \uC0DD\uC0B0\uD55C\uB2E4. \uAC00\uC7A5 \uBCF5\uC7A1\uD558\uACE0
      \uB290\uB9B0 \uC0DD\uC0B0 \uCCB4\uC778\uC774\uC9C0\uB9CC \uCD5C\uACE0\uC758
      \uC774\uC775\uC744 \uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 10166970572226560
    m_Localized: "\uACF5\uC7A5\uC744 \uC6B4\uC601\uD558\uAE30 \uC704\uD574 \uAE30\uBCF8\uC801\uC778
      \uC5F0\uAD6C\uB97C \uC9C4\uD589\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
