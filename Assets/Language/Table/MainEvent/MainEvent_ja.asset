  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 7300000000001
    m_Localized: 労働組合の動き
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001001
    m_Localized: 従業員代表による組織化が進んでいます。紛争が収束するまで、毎日のクレジット支出に影響が出る場合があります。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000002
    m_Localized: 戦時動員
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001002
    m_Localized: 供給混乱と優先調達により、資材調達と納期が不安定になっています。コストとリードタイムに注意してください。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000003
    m_Localized: 自動化プログラム
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001003
    m_Localized: 経営陣が大規模な自動化投資を承認しました。今後の四半期で生産性・保全負荷・人員計画が大きく変わる見込みです。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000004
    m_Localized: 一時金支給の要求
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001004
    m_Localized: 労働者が一時的な共同ボーナスの支払いを要求しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000005
    m_Localized: 残業パイロット制度
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001005
    m_Localized: 労働組合は残業パイロット・プログラムの導入を強く求めています。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000006
    m_Localized: 木材供給の要請
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001006
    m_Localized: 労働組合は休憩室改修のための木材供給を求めています。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000007
    m_Localized: 安全装備の供給
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001007
    m_Localized: 労働者が作業事故防止のために安全用具の供給を要求しています。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000008
    m_Localized: 休憩室家具の交換
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001008
    m_Localized: 労働組合は従業員の休憩スペース整備に向け、基本家具の提供を求めています。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000009
    m_Localized: 防寒衣服の支給
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001009
    m_Localized: 従業員が寒い季節に備えて防寒用の基本衣服の支給を要請しました。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000010
    m_Localized: 福祉基金の寄付
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001010
    m_Localized: 労働組合は労働福祉基金への資金拠出（クレジット提供）を求めています。
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000011
    m_Localized: 福祉政策の導入
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001011
    m_Localized: 労働組合は従業員福祉政策の公式導入を強く求めています。
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
