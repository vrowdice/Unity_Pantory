      m_Items: []
  - m_Id: 864226267034
    m_Localized: "\uAD11\uAD6C \uC804\uC5ED \uC9C0\uC9C8\uB3C4\uB97C \uC644\uC131\uD574
      \uC6B4\uC601 \uAC00\uB2A5\uD55C \uC11D\uD0C4\uAD11 \uC218\uB97C \uCD5C\uB300\uD654\uD569\uB2C8\uB2E4."
