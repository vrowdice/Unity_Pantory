      m_Items: []
  - m_Id: 7000000001002
    m_Localized: "\u6280\u8853\u9769\u65B0\u3068\u653F\u5E9C\u306E\u88DC\u52A9\u91D1\u306B\u3088\u308A\u3001\u81EA\u52D5\u8ECA\u7523\u696D\u304C\u597D\u6CC1\u3092\u8FCE\u3048\u3066\u3044\u307E\u3059\u3002\u81EA\u52D5\u8ECA\u3001\u30A8\u30F3\u30B8\u30F3\u3001\u9244\u92FC\u3001\u30A2\u30EB\u30DF\u30CB\u30A6\u30E0\u3001\u77F3\u6CB9\u306E\u4FA1\u683C\u9AD8\u9A30\u304C\u4E88\u60F3\u3055\u308C\u307E\u3059\u3002"
