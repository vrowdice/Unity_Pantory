  - m_Id: 864226263054
    m_Localized: "\uC218\uC791\uC5C5\uC5D0 \uC219\uB828\uB41C \uAE30\uBCF8 \uB178\uB3D9\uC790.
      \uBAA8\uB4E0 \uC791\uC5C5\uC7A5\uC758 \uAE30\uBC18\uC774 \uB418\uC5B4 \uC721\uCCB4
      \uB178\uB3D9\uACFC \uAE30\uBCF8 \uC81C\uC791 \uC791\uC5C5\uC744 \uB2F4\uB2F9\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226263055
    m_Localized: "\uAE30\uC220\uC801 \uC804\uBB38 \uC9C0\uC2DD\uC744 \uAC00\uC9C4
      \uC219\uB828\uB41C \uC7A5\uC778. \uBCF5\uC7A1\uD55C \uC870\uB9BD\uACFC \uACE0\uAE09
