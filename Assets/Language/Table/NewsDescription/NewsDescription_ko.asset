  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: NewsDescription_ko
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: 50732f9fa28f1df438110b6c9d789e65, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 7000000000001
    m_Localized: 국제 갈등의 격화로 전 세계적인 군비 경쟁이 시작되었습니다. 소형 무기, 중화기, 탄약, 전차의 수요가 폭발적으로 증가하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000002
    m_Localized: 기술적 혁신과 정부 보조금으로 자동차 산업이 호황을 맞았습니다. 자동차, 엔진, 철강, 알루미늄, 석유의 가격 급등이 예상됩니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000003
    m_Localized: 혁신적인 항공 엔진 설계가 시장에 활력을 불어넣었습니다. 비행기, 알루미늄, 엔진, 전자 부품의 수요가 치솟고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000004
    m_Localized: 글로벌 공급망 차질로 반도체 생산이 중단되었습니다. 전자 부품, 정밀 도구, 기계 부품의 가격이 빠르게 상승하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000005
    m_Localized: 대규모 글로벌 쇼핑 이벤트로 창고가 비었습니다. 전자 부품, 기본 및 고급 의류, 가구에 대한 수요가 사상 최고치를 기록했습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000006
    m_Localized: 경제 불안정으로 인해 투자자들이 안전 자산으로 몰리고 있습니다. 금 광석과 순금의 가치가 가파르게 상승하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000007
    m_Localized: 급격한 도시화로 건설 붐이 일었습니다. 철강, 기본 및 고급 가구, 고급 목재의 가격이 급등하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000008
    m_Localized: 새로운 사치 금지법이 사치품 판매를 엄격히 금지합니다. 고급 의류, 고급 가구, 순금 시장이 폭락하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000009
    m_Localized: 주요 광산의 붕괴 사고로 채굴이 중단되었습니다. 석탄, 철 광석, 알루미늄 광석, 금 광석의 부족이 예상됩니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000010
    m_Localized: 산유국 지역의 지정학적 갈등으로 생산량이 급감했습니다. 석유 가격이 전례 없는 수준으로 치솟고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000011
    m_Localized: 역사적인 평화 협정으로 전 세계적인 비무장화가 진행되고 있습니다. 탄약, 전차, 비행기 가격의 하락을 유도합니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000012
    m_Localized: 수입 금속에 대한 중관세 부과로 무역이 차질을 빚고 있습니다. 국내 철강 및 철 광석 가격이 급등하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000013
    m_Localized: 섬유 산업 전반에 걸친 대규모 파업으로 생산이 마비되었습니다. 직물, 기본 의류, 고급 의류가 품귀 현상을 빚고 있습니다.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
