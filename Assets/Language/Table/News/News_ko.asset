  m_TableData:
  - m_Id: 7000000000001
    m_Localized: "\uC804 \uC138\uACC4\uC801 \uAD70\uBE44 \uACBD\uC7C1"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000002
    m_Localized: "\uC790\uB3D9\uCC28 \uBD90"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000003
    m_Localized: "\uD56D\uACF5 \uAE30\uC220\uC758 \uB3CC\uD30C\uAD6C"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000004
    m_Localized: "\uAE00\uB85C\uBC8C \uCE69 \uBD80\uC871 \uD604\uC0C1"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000005
    m_Localized: "\uAE00\uB85C\uBC8C \uC0AC\uC774\uBC84 \uC138\uC77C"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000006
    m_Localized: "\uAE08\uAC12 \uD3ED\uB4F1!"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000007
    m_Localized: "\uAE00\uB85C\uBC8C \uC8FC\uD0DD \uBD90"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000008
    m_Localized: "\uC0AC\uCE58\uD488 \uAE08\uC9C0\uB839"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000009
    m_Localized: "\uAD11\uC0B0 \uBD95\uAD34 \uC0AC\uACE0"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000010
    m_Localized: "\uC624\uC77C \uC1FC\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000011
    m_Localized: "\uC138\uACC4 \uD3C9\uD654 \uC870\uC57D \uCCB4\uACB0"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000012
    m_Localized: "\uCCA0\uAC15 \uAD00\uC138 \uBD80\uACFC"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000013
    m_Localized: "\uC12C\uC720 \uB178\uB3D9\uC790 \uD30C\uC5C5"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001001
    m_Localized: "\uAD6D\uC81C \uAC08\uB4F1\uC758 \uACA9\uD654\uB85C \uC804 \uC138\uACC4\uC801\uC778
      \uAD70\uBE44 \uACBD\uC7C1\uC774 \uC2DC\uC791\uB418\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC18C\uD615 \uBB34\uAE30, \uC911\uD654\uAE30, \uD0C4\uC57D, \uC804\uCC28\uC758
      \uC218\uC694\uAC00 \uD3ED\uBC1C\uC801\uC73C\uB85C \uC99D\uAC00\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001002
    m_Localized: "\uAE30\uC220\uC801 \uD601\uC2E0\uACFC \uC815\uBD80 \uBCF4\uC870\uAE08\uC73C\uB85C
      \uC790\uB3D9\uCC28 \uC0B0\uC5C5\uC774 \uD638\uD669\uC744 \uB9DE\uC558\uC2B5\uB2C8\uB2E4.
      \uC790\uB3D9\uCC28, \uC5D4\uC9C4, \uCCA0\uAC15, \uC54C\uB8E8\uBBF8\uB284, \uC11D\uC720\uC758
      \uAC00\uACA9 \uAE09\uB4F1\uC774 \uC608\uC0C1\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001003
    m_Localized: "\uD601\uC2E0\uC801\uC778 \uD56D\uACF5 \uC5D4\uC9C4 \uC124\uACC4\uAC00
      \uC2DC\uC7A5\uC5D0 \uD65C\uB825\uC744 \uBD88\uC5B4\uB123\uC5C8\uC2B5\uB2C8\uB2E4.
      \uBE44\uD589\uAE30, \uC54C\uB8E8\uBBF8\uB284, \uC5D4\uC9C4, \uC804\uC790 \uBD80\uD488\uC758
      \uC218\uC694\uAC00 \uCE58\uC19F\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001004
    m_Localized: "\uAE00\uB85C\uBC8C \uACF5\uAE09\uB9DD \uCC28\uC9C8\uB85C \uBC18\uB3C4\uCCB4
      \uC0DD\uC0B0\uC774 \uC911\uB2E8\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uC804\uC790
      \uBD80\uD488, \uC815\uBC00 \uB3C4\uAD6C, \uAE30\uACC4 \uBD80\uD488\uC758 \uAC00\uACA9\uC774
      \uBE60\uB974\uAC8C \uC0C1\uC2B9\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001005
    m_Localized: "\uB300\uADDC\uBAA8 \uAE00\uB85C\uBC8C \uC1FC\uD551 \uC774\uBCA4\uD2B8\uB85C
      \uCC3D\uACE0\uAC00 \uBE44\uC5C8\uC2B5\uB2C8\uB2E4. \uC804\uC790 \uBD80\uD488,
      \uAE30\uBCF8 \uBC0F \uACE0\uAE09 \uC758\uB958, \uAC00\uAD6C\uC5D0 \uB300\uD55C
      \uC218\uC694\uAC00 \uC0AC\uC0C1 \uCD5C\uACE0\uCE58\uB97C \uAE30\uB85D\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001006
    m_Localized: "\uACBD\uC81C \uBD88\uC548\uC815\uC73C\uB85C \uC778\uD574 \uD22C\uC790\uC790\uB4E4\uC774
      \uC548\uC804 \uC790\uC0B0\uC73C\uB85C \uBAB0\uB9AC\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uAE08 \uAD11\uC11D\uACFC \uC21C\uAE08\uC758 \uAC00\uCE58\uAC00 \uAC00\uD30C\uB974\uAC8C
      \uC0C1\uC2B9\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001007
    m_Localized: "\uAE09\uACA9\uD55C \uB3C4\uC2DC\uD654\uB85C \uAC74\uC124 \uBD90\uC774
      \uC77C\uC5C8\uC2B5\uB2C8\uB2E4. \uCCA0\uAC15, \uAE30\uBCF8 \uBC0F \uACE0\uAE09
      \uAC00\uAD6C, \uACE0\uAE09 \uBAA9\uC7AC\uC758 \uAC00\uACA9\uC774 \uAE09\uB4F1\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001008
    m_Localized: "\uC0C8\uB85C\uC6B4 \uC0AC\uCE58 \uAE08\uC9C0\uBC95\uC774 \uC0AC\uCE58\uD488
      \uD310\uB9E4\uB97C \uC5C4\uACA9\uD788 \uAE08\uC9C0\uD569\uB2C8\uB2E4. \uACE0\uAE09
      \uC758\uB958, \uACE0\uAE09 \uAC00\uAD6C, \uC21C\uAE08 \uC2DC\uC7A5\uC774 \uD3ED\uB77D\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001009
    m_Localized: "\uC8FC\uC694 \uAD11\uC0B0\uC758 \uBD95\uAD34 \uC0AC\uACE0\uB85C
      \uCC44\uAD74\uC774 \uC911\uB2E8\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uC11D\uD0C4,
      \uCCA0 \uAD11\uC11D, \uC54C\uB8E8\uBBF8\uB284 \uAD11\uC11D, \uAE08 \uAD11\uC11D\uC758
      \uBD80\uC871\uC774 \uC608\uC0C1\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001010
    m_Localized: "\uC0B0\uC720\uAD6D \uC9C0\uC5ED\uC758 \uC9C0\uC815\uD559\uC801
      \uAC08\uB4F1\uC73C\uB85C \uC0DD\uC0B0\uB7C9\uC774 \uAE09\uAC10\uD588\uC2B5\uB2C8\uB2E4.
      \uC11D\uC720 \uAC00\uACA9\uC774 \uC804\uB840 \uC5C6\uB294 \uC218\uC900\uC73C\uB85C
      \uCE58\uC19F\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001011
    m_Localized: "\uC5ED\uC0AC\uC801\uC778 \uD3C9\uD654 \uD611\uC815\uC73C\uB85C
      \uC804 \uC138\uACC4\uC801\uC778 \uBE44\uBB34\uC7A5\uD654\uAC00 \uC9C4\uD589\uB418\uACE0
      \uC788\uC2B5\uB2C8\uB2E4. \uD0C4\uC57D, \uC804\uCC28, \uBE44\uD589\uAE30 \uAC00\uACA9\uC758
      \uD558\uB77D\uC744 \uC720\uB3C4\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001012
    m_Localized: "\uC218\uC785 \uAE08\uC18D\uC5D0 \uB300\uD55C \uC911\uAD00\uC138
      \uBD80\uACFC\uB85C \uBB34\uC5ED\uC774 \uCC28\uC9C8\uC744 \uBE5A\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uAD6D\uB0B4 \uCCA0\uAC15 \uBC0F \uCCA0 \uAD11\uC11D \uAC00\uACA9\uC774 \uAE09\uB4F1\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001013
    m_Localized: "\uC12C\uC720 \uC0B0\uC5C5 \uC804\uBC18\uC5D0 \uAC78\uCE5C \uB300\uADDC\uBAA8
      \uD30C\uC5C5\uC73C\uB85C \uC0DD\uC0B0\uC774 \uB9C8\uBE44\uB418\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC9C1\uBB3C, \uAE30\uBCF8 \uC758\uB958, \uACE0\uAE09 \uC758\uB958\uAC00 \uD488\uADC0
      \uD604\uC0C1\uC744 \uBE5A\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
