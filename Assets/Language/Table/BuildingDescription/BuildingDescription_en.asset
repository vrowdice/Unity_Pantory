  m_Name: BuildingDescription_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 56883579e18354a4c988dc94eb36f1e2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 864226270101
    m_Localized: A chemical processing facility that transforms crude oil into fabric and other synthetic materials. Produces fabric from oil, enabling textile production without relying solely on wood.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270102
    m_Localized: A precision manufacturing facility for producing mechanical components, electronic components, and precision tools. Produces machine parts, electronic components, and precision tools from refined metals. Essential for advanced production chains.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270103
    m_Localized: A specialized facility for manufacturing high-performance internal combustion engines. Produces engines from machine parts, electronic components, and steel ingots. Essential prerequisite for vehicle production.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270104
    m_Localized: A heavy industry facility specializing in precision tools and luxury goods. Produces precision tools and premium products from high-grade steel and advanced components. Requires significant investment but yields high-value products.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270105
    m_Localized: A versatile light industry facility that produces consumer goods including furniture, clothing, and simple tools. Flexible production allows switching between different product lines based on market demand.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270106
    m_Localized: A loading station where resources are picked up from storage and loaded onto the production line. Workers efficiently transfer materials to begin the manufacturing process.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270107
    m_Localized: A wood processing facility that transforms raw logs into fine wood and fabric. Processes wood logs into usable lumber and can also produce fabric from wood pulp. Most efficient when placed near sawmills.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270108
    m_Localized: A military-grade manufacturing facility for producing weapons and munitions. Produces small arms, heavy arms, and munitions from steel ingots and machine parts. Essential for wartime production with high demand during conflicts.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270109
    m_Localized: A deep-shaft mining facility that extracts iron ore, coal, copper ore, gold ore, and aluminum ore from the earth. Requires significant investment but provides essential raw materials for industry.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270110
    m_Localized: An oil drilling facility that extracts crude oil from underground reserves. Essential for fuel production and chemical processing. Requires high maintenance costs.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270111
    m_Localized: A transportation pathway that connects different areas of the production line. Essential infrastructure for moving resources and products efficiently between facilities.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270112
    m_Localized: Harvests raw timber directly from nearby forests. Produces fresh logs without consuming any auxiliary materials.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270113
    m_Localized: A smelting facility that transforms raw ores into refined metal ingots. Processes iron ore, copper ore, aluminum ore, and gold ore into their respective ingots. Essential for metalworking industries.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270114
    m_Localized: An unloading station where finished products are removed from the production line and stored. Workers carefully handle completed items for inventory management.
    m_Metadata:
      m_Items: []
  - m_Id: 864226270115
    m_Localized: A massive industrial facility for assembling vehicles. Requires extensive components, electronics, and materials to produce cars, airplanes, and tanks.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
