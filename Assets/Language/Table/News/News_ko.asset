  m_TableData:
  - m_Id: 7000000000001
    m_Localized: "전 세계적 군비 경쟁"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000002
    m_Localized: "자동차 산업 호황"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000003
    m_Localized: "항공 기술의 돌파구"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000004
    m_Localized: "글로벌 칩 부족"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000005
    m_Localized: "글로벌 사이버 세일"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000006
    m_Localized: "금값 폭등!"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000007
    m_Localized: "글로벌 주택 붐"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000008
    m_Localized: "사치품 금지령"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000009
    m_Localized: "광산 붕괴 사고"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000010
    m_Localized: "오일 쇼크"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000011
    m_Localized: "세계 평화 조약 체결"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000012
    m_Localized: "철강 관세 부과"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000013
    m_Localized: "섬유 노동자 파업"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001001
    m_Localized: "국제 갈등 격화로 전 세계적 군비 경쟁이
      촉발되었습니다. 소화기, 중화기, 탄약, 전차 가격이
      상승하고 있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001002
    m_Localized: "기술 혁신과 보조금으로 자동차 붐이
      일고 있습니다. 자동차, 엔진, 강괴·철 인골, 알루미늄,
      원유 가격이 오르고 있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001003
    m_Localized: "혁신적인 항공 설계가 시장을 삼립니다.
      전투기, 알루미늄, 엔진, 전자 부품 가격이 상승하고
      있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001004
    m_Localized: "공급망 차질로 반도체 생산이 중단되었습니다.
      전자 부품, 정밀 공구, 기계 부품 가격이 급등하고
      있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001005
    m_Localized: "대규모 온라인 세일로 창고가 비었습니다.
      전자 부품, 기본·고급 의류, 가구, 단순 공구 수요가
      사상 최고치입니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001006
    m_Localized: "경제 불안으로 투자자들이 안전 자산으로
      몰리고 있습니다. 금광석과 순금 가격이 급등하고
      있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001007
    m_Localized: "급격한 도시화로 건설 붐이 일었습니다. 강괴,
      기계 부품, 단순 공구, 원목, 좋은 목재, 고급 목재,
      기본·고급 가구 가격이 급등하고 있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001008
    m_Localized: "새 사치 금지법이 고급품 판매를 금지합니다.
      고급 의류, 고급 가구, 순금 가격이 하락하고 있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001009
    m_Localized: "주요 광산 붕괴로 채굴이 중단되었습니다.
      석탄, 철광석, 동광석·동 인골, 알루미늄 광석, 금광석
      가격이 급등하고 있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001010
    m_Localized: "산유국 분쟁으로 생산량이 급감했습니다.
      원유와 석탄 가격이 급등하고 있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001011
    m_Localized: "역사적 평화 조약으로 군사 예산이 줄어드니다.
      소화기, 중화기, 탄약, 전차, 전투기 가격이 하락하고
      있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001012
    m_Localized: "수입 금속 중관세로 무역이 차질을 빚고 있습니다.
      강괴 인골, 철 인골, 철광석 가격이 급등하고 있습니다."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001013
    m_Localized: "섬유 산업 대규모 파업으로 공장이 멈춴졌습니다.
      직물, 기본 의류, 고급 의류 가격이 상승하고 있습니다."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
