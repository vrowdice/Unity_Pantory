  - m_Id: 7000000001003
    m_Localized: "\u9769\u65B0\u7684\u306A\u822A\u7A7A\u30A8\u30F3\u30B8\u30F3\u8A2D\u8A08\u304C\u5E02\u5834\u3092\u6D3B\u6027\u5316\u3055\u305B\u307E\u3057\u305F\u3002\u98DB\u884C\u6A5F\u3001\u30A2\u30EB\u30DF\u30CB\u30A6\u30E0\u3001\u30A8\u30F3\u30B8\u30F3\u3001\u96FB\u5B50\u90E8\u54C1\u306E\u9700\u8981\u304C\u6025\u5897\u3057\u3066\u3044\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001004
    m_Localized: "\u4E16\u754C\u7684\u306A\u30B5\u30D7\u30E9\u30A4\u30C1\u30A7\u30FC\u30F3\u306E\u6DF7\u4E71\u306B\u3088\u308A\u534A\u5C0E\u4F53\u751F\u7523\u304C\u505C\u6B62\u3057\u307E\u3057\u305F\u3002\u96FB\u5B50\u90E8\u54C1\u3001\u7CBE\u5BC6\u5DE5\u5177\u3001\u6A5F\u68B0\u90E8\u54C1\u306E\u4FA1\u683C\u304C\u6025\u901F\u306B\u4E0A\u6607\u3057\u3066\u3044\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001005
    m_Localized: "\u5927\u898F\u6A21\u306A\u4E16\u754C\u7684\u30B7\u30E7\u30C3\u30D4\u30F3\u30B0\u30A4\u30D9\u30F3\u30C8\u306B\u3088\u308A\u5009\u5EAB\u304C\u7A7A\u306B\u306A\u308A\u307E\u3057\u305F\u3002\u96FB\u5B50\u90E8\u54C1\u3001\u8863\u985E\uFF08\u4E00\u822C\u30FB\u9AD8\u7D1A\uFF09\u3001\u5BB6\u5177\u306E\u9700\u8981\u304C\u904E\u53BB\u6700\u9AD8\u3092\u8A18\u9332\u3057\u307E\u3057\u305F\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001006
    m_Localized: "\u7D4C\u6E08\u306E\u4E0D\u5B89\u5B9A\u5316\u306B\u3088\u308A\u3001\u6295\u8CC7\u5BB6\u304C\u5B89\u5168\u8CC7\u7523\u306B\u6BBA\u5230\u3057\u3066\u3044\u307E\u3059\u3002\u91D1\u9271\u77F3\u3068\u7D14\u91D1\u306E\u4FA1\u5024\u304C\u6025\u4E0A\u6607\u3057\u3066\u3044\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001007
    m_Localized: "\u6025\u901F\u306A\u90FD\u5E02\u5316\u306B\u3088\u308A\u5EFA\u8A2D\u30E9\u30C3\u30B7\u30E5\u304C\u8D77\u304D\u3066\u3044\u307E\u3059\u3002\u9244\u92FC\u3001\u5BB6\u5177\uFF08\u4E00\u822C\u30FB\u9AD8\u7D1A\uFF09\u3001\u9AD8\u7D1A\u6728\u6750\u306E\u4FA1\u683C\u304C\u6025\u9A30\u3057\u3066\u3044\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 7000000001008
    m_Localized: "\u65B0\u3057\u3044\u5962\u4F88\u7981\u6B62\u4EE4\u306B\u3088\u308A\u3001\u8D05\u6CA2\u54C1\u306E\u8CA9\u58F2\u304C\u53B3\u3057\u304F\u7981\u3058\u3089\u308C\u307E\u3057\u305F\u3002\u9AD8\u7D1A\u8863\u985E\u3001\u9AD8\u7D1A\u5BB6\u5177\u3001\u7D14\u91D1\u306E\u5E02\u5834\u304C\u66B4\u843D\u3057\u3066\u3044\u307E\u3059\u3002"
