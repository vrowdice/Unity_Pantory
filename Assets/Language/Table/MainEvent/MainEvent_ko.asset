  m_SharedData: {fileID: 11400000, guid: 074d4667c5b0cd34fbfd9ac5787afa5c, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 7300000000001
    m_Localized: 노조 조직화
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001001
    m_Localized: 근로자 대표의 조직화가 본격화됩니다. 분쟁이 정리될 때까지 매일 크레딧 지출에 변동이 생길 수 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000002
    m_Localized: 전시 동원
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001002
    m_Localized: 공급난과 우선 조달로 자재 확보와 납기가 불안정해졌습니다. 비용과 리드타임 변동에 대비하세요.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000003
    m_Localized: 자동화 프로그램
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001003
    m_Localized: 경영진이 대규모 자동화 투자를 승인했습니다. 향후 분기 동안 생산성·정비 부담·인력 계획이 크게 달라질 수 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000004
    m_Localized: 집단 성과금 요구
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001004
    m_Localized: 노동자들이 일회성 집단 성과금 지급을 요구하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000005
    m_Localized: 초과 근무 시범 제도
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001005
    m_Localized: 노조 협상단이 초과 근무 시범 프로그램 도입을 요구하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000006
    m_Localized: 목재 보급 요청
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001006
    m_Localized: 노조가 휴게실 리모델링을 위한 목재 보급을 요청했습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000007
    m_Localized: 안전 장비 보급
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001007
    m_Localized: 노동자들이 작업장 사고 예방을 위한 안전 장비 보급을 요구하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000008
    m_Localized: 휴게실 가구 교체
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001008
    m_Localized: 노조가 노동자 휴게 공간 정비를 위해 기본 가구 지원을 요청했습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000009
    m_Localized: 방한 의복 지급
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001009
    m_Localized: 근로자들이 추운 계절을 대비해 방한용 기본 의복 지급을 요청했습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000010
    m_Localized: 복지 기금 기부
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001010
    m_Localized: 노조가 근로 복지 기금에 자금 출자(크레딧 지원)를 요구하고 있습니다.
    m_Metadata:
      m_Items: []
  - m_Id: 7300000000011
    m_Localized: 복지 제도 채택
    m_Metadata:
      m_Items: []
  - m_Id: 7300000001011
    m_Localized: 노조 협상단이 근로자 복지 정책의 공식 도입을 요구하고 있습니다.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
