  m_SharedData: {fileID: 11400000, guid: ffeffd319fd382447972467e83303c2a, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 864226267001
    m_Localized: 부품 공장 건설을 해금한다. 정제된 금속 주괴로 기계 부품, 전자 부품, 정밀 공구 등을 생산할 수 있다. 중반 생산 체인의 시작점이 되어 고급 건물 및 차량 생산에 필수적인 재료를 공급한다.
    m_Metadata:
      m_Items: []
  - m_Id: 864226267002
    m_Localized: 광산 건설을 해금한다. 철광석, 석탄, 구리, 금, 알루미늄 등 필수 광물의 자급을 가능하게 한다. 건설·유지 비용은 높지만 산업의 기반이 되는 원자재를 공급한다.
    m_Metadata:
      m_Items: []
  - m_Id: 864226267003
    m_Localized: 화학 공장 건설을 해금한다. 원유를 합성 섬유와 화학 제품으로 가공한다. 제재소의 대안이자 보완으로, 석유 기반 직물 생산으로 목재 의존을 줄인다.
    m_Metadata:
      m_Items: []
  - m_Id: 864226267004
    m_Localized: 중공업 공장 건설을 해금한다. 고급 강재와 최신 부품으로 정밀 공구와 고급 제품을 생산한다. 상당한 투자가 필요하지만 고급 시장을 겨냥해 이익률을 극대화한다.
    m_Metadata:
      m_Items: []
  - m_Id: 864226267005
    m_Localized: 유정 건설을 해금한다. 지하의 원유를 채굴한다. 전략 자원 자급의 시작점이다. 유지 비용이 매우 높지만 화학 산업과 연료 생산의 기반을 이룬다.
    m_Metadata:
      m_Items: []
  - m_Id: 864226267006
    m_Localized: 제련소 건설을 해금한다. 광산에서 채굴한 원광석을 정제 금속 주괴로 가공한다. 철·구리·알루미늄 주괴 등을 생산해 금속 산업에 필수적인 중간 재료를 공급한다.
    m_Metadata:
      m_Items: []
  - m_Id: 864226267007
    m_Localized: 엔진 공장 건설을 해금한다. 기계 부품, 전자 부품, 강 주괴를 조합해 고성능 내연기관을 생산한다. 차량 생산을 위한 선행 투자이며, 고부가가치 중간 재료 생산을 시작한다.
    m_Metadata:
      m_Items: []
  - m_Id: 864226267008
    m_Localized: 군사 공장 건설을 해금한다. 강 주괴와 기계 부품으로 소화기, 중화기, 탄약 등을 생산한다. 국가의 전략 자원으로, 전쟁 준비와 무기 시장 장악에 필수적이다.
    m_Metadata:
      m_Items: []
  - m_Id: 864226267009
    m_Localized: 차량 조립 공장 건설을 해금한다. 엔진, 부품, 전자 부품 등을 조합해 자동차, 전투기, 전차 등 최고 부가가치 최종 제품을 생산한다. 가장 복잡하고 느린 생산 체인이지만 최고의 이익을 낸다.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
