  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: TutorialGuided_ko
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: 55d80ac21c79dd14f8e1397ca6e4b64d, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 2578400000000016
    m_Localized: "\uBA3C\uC800 \uC870\uC791 \uBC29\uBC95\uC744 \uC775\uD600 \uBCF4\uC138\uC694.
      \uB9C8\uC6B0\uC2A4 \uB4DC\uB798\uADF8 \uB610\uB294 WASD\uB85C \uD654\uBA74\uC744
      \uC774\uB3D9\uD558\uACE0, \uB9C8\uC6B0\uC2A4 \uD720\uB85C \uD655\uB300\xB7\uCD95\uC18C\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000000
    m_Localized: "\uAE30\uCD08\uC801\uC778 \uC0DD\uC0B0 \uB77C\uC778\uC778 \uBC8C\uBAA9\uC7A5\uACFC
      \uD558\uC5ED\uC7A5, \uC81C\uC7AC\uC18C, \uC801\uC7AC\uC7A5\uC744 \uBC30\uCE58\uD558\uACE0
      \uB3C4\uB85C\uB85C \uC5F0\uACB0\uD558\uB294 \uBC29\uBC95\uC744 \uBC30\uC6C1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000013
    m_Localized: "\uC81C\uAC70 \uBAA8\uB4DC\uB97C \uBC30\uC6CC \uBD05\uC2DC\uB2E4.
      \uB9F5 \uC67C\uCABD \uC704\uC5D0 \uC5F0\uC2B5\uC6A9 \uB3C4\uB85C\uAC00 \uC788\uC2B5\uB2C8\uB2E4.
      \uC81C\uAC70 \uBAA8\uB4DC\uB85C \uAC74\uBB3C\uACFC \uB3C4\uB85C\uB97C \uC9C0\uC6B8
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000014
    m_Localized: "\uC81C\uAC70 \uBAA8\uB4DC \uC2A4\uC704\uCE58\uB97C \uCF1C\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000015
    m_Localized: "\uB9F5\uC758 \uC67C\uCABD \uC704\uC5D0 \uC5F0\uC2B5\uC6A9 \uB3C4\uB85C\uAC00
      \uC788\uC2B5\uB2C8\uB2E4. \uC67C\uCABD \uC704\uB85C \uC774\uB3D9\uD558\uACE0
      \uADF8\uB9AC\uB4DC\uC758 \uC5F0\uC2B5\uC6A9 \uB3C4\uB85C\uB97C \uD074\uB9AD\uD574
      \uC81C\uAC70\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30819995552727040
    m_Localized: "\uD310\uD1A0\uB9AC\uC5D0\uB294 \uD3B8\uB9AC\uD55C \uC9C1\uC6D0
      \uC790\uB3D9 \uBC30\uCE58 \uAE30\uB2A5\uC774 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30820150800695296
    m_Localized: "\uAC01 \uACF5\uC7A5\uC5D0\uB294 \uBC18\uB4DC\uC2DC \uC9C1\uC6D0\uC774
      \uD544\uC694\uD558\uACE0, \uC9C1\uC6D0 \uB9CC\uC871\uB3C4\uB97C \uAD00\uB9AC\uD558\uB294
      \uAC83\uB3C4 \uB9E4\uC6B0 \uC911\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30820695795974144
    m_Localized: "\uC9C1\uC6D0 \uC790\uB3D9 \uBC30\uCE58 \uAE30\uB2A5\uC744 \uCF1C\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30820797528817664
    m_Localized: "\uC774\uC81C \uC9C1\uC6D0\uC744 \uC9C1\uC811 \uACE0\uC6A9\uD558\uC9C0
      \uC54A\uC544\uB3C4 \uC790\uB3D9\uC73C\uB85C \uBC30\uCE58\uB429\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665216
    m_Localized: "\uBCF8\uACA9\uC801\uC73C\uB85C \uACE0\uAE09 \uBAA9\uC7AC \uC0DD\uC0B0
      \uB77C\uC778\uC744 \uB9CC\uB4E4\uC5B4 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000001
    m_Localized: "\uBC8C\uBAA9\uC7A5\uC744 \uC120\uD0DD\uD558\uC138\uC694. \uBC8C\uBAA9\uD55C
      \uC6D0\uBAA9\uC740 \uB3C4\uB85C \uC5C6\uC774 \uCC3D\uACE0\uB85C \uBC14\uB85C
      \uBCF4\uB0C5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000002
    m_Localized: "\uBC8C\uBAA9\uC7A5\uC744 \uADF8\uB9AC\uB4DC\uC5D0 \uBC30\uCE58\uD558\uC138\uC694.
      \uB3C4\uB85C \uC5F0\uACB0\uC740 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665225
    m_Localized: "\uAC74\uC124 \uBAA8\uB4DC\uC5D0\uC11C \uBC97\uC5B4\uB098\uB824\uBA74
      \uB9C8\uC6B0\uC2A4 \uC624\uB978\uCABD \uD074\uB9AD\uC774\uB098 \uAC74\uBB3C
      \uBC84\uD2BC\uC744 \uB2E4\uC2DC \uB204\uB974\uBA74 \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000003
    m_Localized: "\uD558\uC5ED\uC7A5\uC744 \uC120\uD0DD\uD558\uC138\uC694. \uCC3D\uACE0\uC5D0
      \uC788\uB294 \uC790\uC6D0\uC744 \uACF5\uC7A5\uC73C\uB85C \uBCF4\uB0B4\uB294
      \uCD9C\uAD6C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000004
    m_Localized: "\uD558\uC5ED\uC7A5\uC744 \uADF8\uB9AC\uB4DC\uC5D0 \uBC30\uCE58\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665233
    m_Localized: "\uB178\uB780 \uD654\uC0B4\uD45C\uB294 \uC790\uC6D0\uC774 \uB2E4\uC74C\uC73C\uB85C
      \uC774\uB3D9\uD560 \uADF8\uB9AC\uB4DC \uCE78\uC744 \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665226
    m_Localized: "\uD558\uC5ED\uC7A5\uC744 \uC5F0\uACB0\uD558\uAE30 \uC704\uD574
      \uB3C4\uB85C\uB97C \uC120\uD0DD\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665227
    m_Localized: "\uD558\uC5ED\uC7A5 \uC606\uC5D0 \uB3C4\uB85C\uB97C \uD55C \uCE78
      \uBC30\uCE58\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000005
    m_Localized: "\uC81C\uC7AC\uC18C\uB97C \uC120\uD0DD\uD558\uC138\uC694. \uC6D0\uBAA9\uC744
      \uAC00\uACF5\uD574 \uACE0\uAE09 \uBAA9\uC7AC\uB97C \uC0DD\uC0B0\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000006
    m_Localized: "\uB3C4\uB85C \uBC14\uB85C \uC606\uC5D0, \uC624\uB978\uCABD \uBC29\uD5A5\uC73C\uB85C
      \uC81C\uC7AC\uC18C\uB97C \uBC30\uCE58\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665228
    m_Localized: "\uB2E4\uC2DC \uB3C4\uB85C\uB97C \uC120\uD0DD\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665229
    m_Localized: "\uC81C\uC7AC\uC18C \uC606\uC5D0 \uB3C4\uB85C\uB97C \uD55C \uCE78
      \uBC30\uCE58\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000009
    m_Localized: "\uC801\uC7AC\uC7A5\uC744 \uC120\uD0DD\uD558\uC138\uC694. \uACF5\uC7A5\uC5D0\uC11C
      \uB098\uC628 \uC790\uC6D0\uC744 \uBC1B\uC544 \uCC3D\uACE0\uB85C \uBCF4\uB0B4\uB294
      \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000010
    m_Localized: "\uB9C8\uC9C0\uB9C9\uC73C\uB85C \uC124\uCE58\uD55C \uB3C4\uB85C
      \uBC14\uB85C \uC624\uB978\uCABD\uC5D0 \uC801\uC7AC\uC7A5\uC744 \uBC30\uCE58\uD558\uC138\uC694.
      \uC5B4\uB290 \uBC29\uD5A5\uC73C\uB85C \uBC30\uCE58\uD574\uB3C4 \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665234
    m_Localized: "\uAC01 \uAC74\uBB3C\uC740 \uB0B4\uBCF4\uB0BC \uC790\uC6D0\uC744
      \uC9C0\uC815\uD574\uC57C \uD569\uB2C8\uB2E4. \uC124\uCE58\uD588\uB358 \uD558\uC5ED\uC7A5\uC744
      \uD074\uB9AD\uD558\uACE0 '\uC6D0\uBAA9' \uC790\uC6D0\uC744 \uC9C0\uC815\uD574
      \uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665235
    m_Localized: "\uB2E4\uC74C\uC73C\uB85C \uC81C\uC7AC\uC18C\uB97C \uD074\uB9AD\uD558\uACE0
      '\uACE0\uAE09 \uBAA9\uC7AC' \uC790\uC6D0\uC744 \uC9C0\uC815\uD574 \uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665236
    m_Localized: "\uC801\uC7AC\uC7A5\uC740 \uBAA8\uB4E0 \uC790\uC6D0\uC744 \uBC1B\uC744
      \uC218 \uC788\uC5B4 \uB530\uB85C \uC9C0\uC815\uD560 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665237
    m_Localized: "\uC774\uC81C \uACF5\uC7A5\uC744 \uC791\uB3D9\uC2DC\uCF1C \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665230
    m_Localized: "\uACF5\uC7A5\uC744 \uC2E4\uC81C\uB85C \uC791\uB3D9\uC2DC\uD0A4\uB824\uBA74
      \uC2DC\uAC04\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665231
    m_Localized: "\uC2DC\uAC04 \uD328\uB110\uC5D0\uC11C \uACF5\uC7A5\uC758 \uC2DC\uAC04\uC744
      \uD750\uB974\uAC8C \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665232
    m_Localized: "\uC2A4\uD0C0\uD2B8 \uBC84\uD2BC\uC744 \uB20C\uB7EC \uACF5\uC7A5\uC758
      \uC2DC\uAC04\uC744 \uD750\uB974\uAC8C \uD574 \uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665238
    m_Localized: "\uC2DC\uAC04\uC744 \uD750\uB974\uBA74\uC11C \uD654\uBA74 \uC624\uB978\uCABD
      \uC790\uC6D0 \uD328\uB110\uC744 \uD655\uC778\uD574 \uBCF4\uC138\uC694. \uC2DC\uAC04\uC774
      \uC9C0\uB0A0\uC218\uB85D \uC790\uC6D0\uC774 \uC774\uB3D9\uD558\uACE0, \uC0DD\uC0B0\uB418\uACE0,
      \uC18C\uBAA8\uB418\uB294 \uAC83\uC744 \uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000011
    m_Localized: "\uC774\uC81C \uC0DD\uC0B0\uD55C \uC790\uC6D0\uC744 \uD314\uC544\uC11C
      \uC774\uB4DD\uC744 \uBCFC \uC2DC\uAC04\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578400000000012
    m_Localized: "\uD29C\uD1A0\uB9AC\uC5BC\uC744 \uC644\uB8CC\uD588\uC2B5\uB2C8\uB2E4.
      \uBCF8 \uAC8C\uC784\uC744 \uC2DC\uC791\uD560 \uC900\uBE44\uAC00 \uB418\uC5C8\uC2B5\uB2C8\uB2E4.
      \uACC4\uC18D\uD558\uBA74 \uC0C8 \uACF5\uC7A5\uC5D0\uC11C \uC2DC\uC791\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665239
    m_Localized: "\uC67C\uCABD\uC758 \uC2DC\uC7A5 \uBC84\uD2BC\uC744 \uB20C\uB7EC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665240
    m_Localized: "\uB9C8\uC774\uB108\uC2A4 \uBC84\uD2BC\uC744 \uC774\uC6A9\uD574
      \uB0A0\uB9C8\uB2E4 \uC790\uC6D0\uC744 \uD310\uB9E4\uD574 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665241
    m_Localized: "\uC67C\uCABD \uC704\uC5D0 \uD06C\uB808\uB527\uACFC \uC5F0\uAD6C\uD3EC\uC778\uD2B8\uAC00
      \uC801\uD600 \uC788\uB294 \uBC84\uD2BC\uC744 \uD1B5\uD574 \uD604\uC7AC \uC790\uAE08
      \uC0C1\uD669\uC744 \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30821035190665242
    m_Localized: "\uAC74\uBB3C \uBC30\uCE58 \uC911\uC5D0\uB294 Q/E\uC640 \uC624\uB978\uCABD
      \uD558\uB2E8 \uD68C\uC804 \uBC84\uD2BC\uC73C\uB85C \uD68C\uC804\uD560 \uC218
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
