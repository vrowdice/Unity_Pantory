  - m_Id: 864226270010
    m_Localized: "\uC720\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 864226270011
    m_Localized: "\uB3C4\uB85C"
    m_Metadata:
      m_Items: []
  - m_Id: 864226270012
    m_Localized: "\uC81C\uC7AC\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 864226270013
    m_Localized: "\uC81C\uB828\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 864226270014
    m_Localized: "\uD558\uC5ED\uC7A5"
    m_Metadata:
      m_Items: []
  - m_Id: 864226270015
    m_Localized: "\uCC28\uB7C9 \uC870\uB9BD \uACF5\uC7A5"
    m_Metadata:
      m_Items: []
  - m_Id: 864226270101
    m_Localized: "\uC6D0\uC720\uB97C \uC9C1\uBB3C \uBC0F \uAE30\uD0C0 \uD569\uC131
      \uC7AC\uB8CC\uB85C \uBCC0\uD658\uD558\uB294 \uD654\uD559 \uCC98\uB9AC \uC2DC\uC124.
      \uC11D\uC720\uC5D0\uC11C \uC9C1\uBB3C\uC744 \uC0DD\uC0B0\uD558\uC5EC \uBAA9\uC7AC\uC5D0\uB9CC
      \uC758\uC874\uD558\uC9C0 \uC54A\uACE0 \uC12C\uC720 \uC0DD\uC0B0\uC744 \uAC00\uB2A5\uD558\uAC8C
      \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270102
    m_Localized: "\uAE30\uACC4 \uBD80\uD488, \uC804\uC790 \uBD80\uD488, \uC815\uBC00
      \uACF5\uAD6C\uB97C \uC0DD\uC0B0\uD558\uB294 \uC815\uBC00 \uC81C\uC870 \uC2DC\uC124.
      \uC815\uC81C \uAE08\uC18D\uC73C\uB85C \uBD80\uD488\xB7\uC804\uC790 \uBD80\uD488\xB7\uC815\uBC00
      \uACF5\uAD6C\uB97C \uC81C\uC870. \uACE0\uAE09 \uC0DD\uC0B0 \uCCB4\uC778\uC5D0
      \uD544\uC218\uC801\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270103
    m_Localized: "\uACE0\uC131\uB2A5 \uB0B4\uC5F0 \uAE30\uAD00\uC744 \uC81C\uC870\uD558\uB294
      \uC804\uBB38 \uC2DC\uC124. \uAE30\uACC4 \uBD80\uD488, \uC804\uC790 \uBD80\uD488,
      \uAC15\uAD34\uB85C \uC5D4\uC9C4\uC744 \uC0DD\uC0B0. \uCC28\uB7C9 \uC0DD\uC0B0\uC758
      \uC120\uD589 \uC870\uAC74\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270104
    m_Localized: "\uC815\uBC00 \uACF5\uAD6C\uC640 \uACE0\uAE09\uD488\uC744 \uC804\uBB38\uC73C\uB85C
      \uD558\uB294 \uC911\uACF5\uC5C5 \uC2DC\uC124. \uACE0\uAE09 \uAC15\uCCA0\uACFC
      \uCCA8\uB2E8 \uBD80\uD488\uC73C\uB85C \uC815\uBC00 \uACF5\uAD6C\uC640 \uACE0\uAE09\uD488\uC744
      \uC0DD\uC0B0. \uD22C\uC790 \uADDC\uBAA8\uB294 \uD06C\uC9C0\uB9CC \uACE0\uBD80\uAC00\uAC00\uCE58
      \uC81C\uD488\uC744 \uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270105
    m_Localized: "\uAC00\uAD6C, \uC758\uB958, \uB2E8\uC21C \uACF5\uAD6C \uB4F1 \uC18C\uBE44\uC7AC\uB97C
      \uC0DD\uC0B0\uD558\uB294 \uB2E4\uC6A9\uB3C4 \uACBD\uACF5\uC5C5 \uC2DC\uC124.
      \uC2DC\uC7A5 \uC218\uC694\uC5D0 \uB530\uB77C \uC0DD\uC0B0 \uB77C\uC778\uC744
      \uC804\uD658\uD560 \uC218 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270106
    m_Localized: "\uC800\uC7A5\uC18C\uC5D0\uC11C \uC790\uC6D0\uC744 \uAC00\uC838\uC640
      \uC0DD\uC0B0 \uB77C\uC778\uC5D0 \uC801\uC7AC\uD558\uB294 \uC801\uC7AC\uC5ED.
      \uC791\uC5C5\uC790\uAC00 \uC790\uC7AC\uB97C \uD6A8\uC728\uC801\uC73C\uB85C
      \uC774\uC1A1\uD574 \uC81C\uC870\uB97C \uC2DC\uC791\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270116
    m_Localized: "\uC778\uADFC \uC232\uC5D0\uC11C \uC6D0\uBAA9\uC744 \uC9C1\uC811
      \uCC44\uBC8C\uD558\uB294 \uBC8C\uBAA9\uC7A5. \uBCF4\uC870 \uC790\uC7AC \uC5C6\uC774
      \uC6D0\uBAA9\uC744 \uC0DD\uC0B0\uD558\uBA70, \uBAA9\uC7AC \uC0DD\uC0B0 \uCCB4\uC778\uC758
      \uCCAB \uB2E8\uACC4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270108
    m_Localized: "\uBB34\uAE30\uC640 \uD0C4\uC57D\uC744 \uC0DD\uC0B0\uD558\uB294
      \uAD70\uC6A9 \uC81C\uC870 \uC2DC\uC124. \uAC15\uAD34\uC640 \uAE30\uACC4 \uBD80\uD488\uC73C\uB85C
      \uC18C\uD654\uAE30, \uC911\uD654\uAE30, \uD0C4\uC57D\uC744 \uC81C\uC870. \uC804\uC2DC
      \uC0DD\uC0B0\uC5D0 \uD544\uC218\uC774\uBA70 \uBD84\uC7C1 \uC2DC \uC218\uC694\uAC00
      \uB192\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270109
    m_Localized: "\uC9C0\uD558\uC5D0\uC11C \uCCA0\uAD11\uC11D, \uC11D\uD0C4, \uB3D9\uAD11\uC11D,
      \uAE08\uAD11\uC11D, \uC54C\uB8E8\uBBF8\uB284 \uAD11\uC11D\uC744 \uCC44\uAD74\uD558\uB294
      \uAC31\uB3C4 \uAD11\uC0B0 \uC2DC\uC124. \uD22C\uC790 \uADDC\uBAA8\uB294 \uD06C\uC9C0\uB9CC
      \uC0B0\uC5C5\uC758 \uAE30\uCD08 \uC6D0\uB8CC\uB97C \uACF5\uAE09\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270110
    m_Localized: "\uC9C0\uD558 \uB9E4\uC7A5\uCE35\uC5D0\uC11C \uC6D0\uC720\uB97C
      \uCC44\uCDE8\uD558\uB294 \uC720\uC815 \uC2DC\uC124. \uC5F0\uB8CC \uC0DD\uC0B0\uACFC
      \uD654\uD559 \uCC98\uB9AC\uC5D0 \uD544\uC218. \uC720\uC9C0 \uBE44\uC6A9\uC774
      \uB192\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270111
    m_Localized: "\uC0DD\uC0B0 \uB77C\uC778\uC758 \uAC01 \uAD6C\uC5ED\uC744 \uC5F0\uACB0\uD558\uB294
      \uC6B4\uC1A1\uB85C. \uC790\uC6D0\uACFC \uC81C\uD488\uC744 \uC2DC\uC124 \uAC04\uC5D0
      \uD6A8\uC728\uC801\uC73C\uB85C \uC774\uB3D9\uC2DC\uD0A4\uB294 \uAE30\uBC18
      \uC2DC\uC124\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270112
    m_Localized: "\uC778\uADFC \uC232\uC5D0\uC11C \uC6D0\uBAA9\uC744 \uC9C1\uC811
      \uCC44\uBC8C\uD558\uB294 \uBC8C\uBAA9\uC7A5. \uBCF4\uC870 \uC790\uC7AC \uC5C6\uC774
      \uC6D0\uBAA9\uC744 \uC0DD\uC0B0\uD558\uBA70, \uBAA9\uC7AC \uC0DD\uC0B0 \uCCB4\uC778\uC758
      \uCCAB \uB2E8\uACC4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270113
    m_Localized: "\uC6D0\uAD11\uC11D\uC744 \uC815\uC81C \uAE08\uC18D \uAD34\uB85C
      \uBCC0\uD658\uD558\uB294 \uC81C\uB828 \uC2DC\uC124. \uCCA0\xB7\uB3D9\xB7\uC54C\uB8E8\uBBF8\uB284\xB7\uAE08
      \uAD11\uC11D\uC744 \uAC01\uAC01\uC758 \uAD34\uB85C \uAC00\uACF5. \uAE08\uC18D
      \uACF5\uC5C5\uC5D0 \uD544\uC218\uC801\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270114
    m_Localized: "\uC0DD\uC0B0 \uB77C\uC778\uC5D0\uC11C \uC644\uC81C\uD488\uC744
      \uB0B4\uB824 \uC800\uC7A5\uD558\uB294 \uD558\uC5ED\uC5ED. \uC791\uC5C5\uC790\uAC00
      \uC644\uC81C\uD488\uC744 \uC2E0\uC911\uD788 \uB2E4\uB8E8\uC5B4 \uC7AC\uACE0\uB97C
      \uAD00\uB9AC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270115
    m_Localized: "\uCC28\uB7C9\uC744 \uC870\uB9BD\uD558\uB294 \uB300\uADDC\uBAA8
      \uC0B0\uC5C5 \uC2DC\uC124. \uB300\uB7C9\uC758 \uBD80\uD488\xB7\uC804\uC790
      \uBD80\uD488\xB7\uC790\uC7AC\uAC00 \uD544\uC694\uD558\uBA70 \uC790\uB3D9\uCC28,
      \uD56D\uACF5\uAE30, \uC804\uCC28\uB97C \uC0DD\uC0B0\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226270201
    m_Localized: "\uC720\uD1B5"
    m_Metadata:
      m_Items: []
  - m_Id: 864226270202
    m_Localized: "\uC0DD\uC0B0"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
