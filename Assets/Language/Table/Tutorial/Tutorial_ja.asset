  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Tutorial_ja
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ja
  m_SharedData: {fileID: 11400000, guid: e00198e87a257ff41b02cc989c3a409a, type: 2}
  m_Metadata:
    m_Items:
    - rid: 2319839819189715042
  m_TableData:
  - m_Id: 11264212992
    m_Localized: "\u3053\u3093\u306B\u3061\u306F\uFF01\u30D1\u30F3\u30C8\u30EA\u30FC\u3078\u3088\u3046\u3053\u305D\uFF01"
    m_Metadata:
      m_Items:
      - rid: 2319839819189715042
  - m_Id: 438890283008
    m_Localized: "\u30D1\u30F3\u30C8\u30EA\u30FC\u306F\u5DE5\u5834\u7D4C\u55B6\u30B7\u30DF\u30E5\u30EC\u30FC\u30B7\u30E7\u30F3\u30B2\u30FC\u30E0\u3067\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 575934971904
    m_Localized: "まず画面の見方を説明します。各メインパネルの（？）ボタンから、いつでもこのヘルプを開けます。"
    m_Metadata:
      m_Items: []
  - m_Id: 1678642659328
    m_Localized: "左上のクレジットと研究ポイント表示をタップすると、詳しい増減を確認できます。"
    m_Metadata:
      m_Items: []
  - m_Id: 2291514359808
    m_Localized: "\u3053\u306E\u30A8\u30EA\u30A2\u306B\u306F\u5F93\u696D\u54E1\u306E\u96C7\u7528\u72B6\u6CC1\u3001\u914D\u7F6E\u3001\u6E80\u8DB3\u5EA6\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2320476028928
    m_Localized: "ゲーム内の日付・時刻のほか、チュートリアル再表示や設定へ進むボタンがあります。"
    m_Metadata:
      m_Items: []
  - m_Id: 2777508364288
    m_Localized: "倉庫・発注・市場・従業員・研究・ニュース・財務へ飛ぶショートカットです。キーボードのF1〜F9でも同じパネルを開けます。"
    m_Metadata:
      m_Items: []
  - m_Id: 5943566155776
    m_Localized: "\u7269\u6D41\u306F\u5DE5\u5834\u904B\u55B6\u306E\u4E2D\u5FC3\u3067\u3059\u3002\u30B9\u30C6\u30FC\u30B7\u30E7\u30F3\u3068\u751F\u7523\u5EFA\u7269\u3092\u9053\u8DEF\u3067\u3064\u306A\u304E\u3001\u5165\u51FA\u529B\u306E\u5411\u304D\u3092\u6B63\u3057\u304F\u5408\u308F\u305B\u308B\u3053\u3068\u3067\u3001\u8CC7\u6E90\u30D1\u30B1\u30C3\u30C8\u3092\u6B62\u3081\u305A\u306B\u6D41\u305B\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 7203816095744
    m_Localized: "基本の流れは荷下ろし→道路→生産建物→道路→積み込みです。荷下ろしが原料を引き込み、生産が加工し、積み込みが製品を倉庫方向へ送ります。"
    m_Metadata:
      m_Items: []
  - m_Id: 7579063697408
    m_Localized: "建物ボタンはカテゴリごとに分かれています。流通には道路・スプリッター・トンネルがあります。生産建物の多くは研究で解放されます。ブループリントタブで配置を保存し、後からまとめて配置できます。"
    m_Metadata:
      m_Items: []
  - m_Id: 7894026567680
    m_Localized: "この一覧から建物と道路を選び、グリッド上で回転を確認して配置します。入力を押し続けると道路を連続配置できます。"
    m_Metadata:
      m_Items: []
  - m_Id: 8131256401920
    m_Localized: "\u3053\u306E\u30D1\u30CD\u30EB\u3067\u5728\u5EAB\u3092\u78BA\u8A8D\u3067\u304D\u307E\u3059\u3002\u30E9\u30A4\u30F3\u304C\u6B62\u307E\u3063\u305F\u3068\u304D\u306F\u3001\u4E0A\u6D41\u8CC7\u6750\u306E\u6709\u7121\u3001\u9053\u8DEF\u65B9\u5411\u3001\u5EFA\u7269\u306E\u5411\u304D\u3001\u51FA\u529B\u5148\u306E\u63A5\u7D9A\u5148\u3092\u9806\u756A\u306B\u78BA\u8A8D\u3059\u308B\u3068\u539F\u56E0\u3092\u7279\u5B9A\u3057\u3084\u3059\u304F\u306A\u308A\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 9056704413696
    m_Localized: "\u826F\u3044\u7269\u6D41\u8A2D\u8A08\u306E\u57FA\u672C\u306F\u3001\u77ED\u3044\u7D4C\u8DEF\u3001\u660E\u78BA\u306A\u65B9\u5411\u3001\u51FA\u529B\u306E\u5206\u6563\u3067\u3059\u3002\u5DE5\u5834\u304C\u62E1\u5F35\u3057\u305F\u3089\u30DC\u30C8\u30EB\u30CD\u30C3\u30AF\u3092\u89B3\u5BDF\u3057\u3001\u30B9\u30D7\u30EA\u30C3\u30BF\u30FC\u3068\u30C8\u30F3\u30CD\u30EB\u3092\u4F7F\u3063\u3066\u51E6\u7406\u91CF\u3092\u5B89\u5B9A\u3055\u305B\u307E\u3057\u3087\u3046\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 11779361357824
    m_Localized: "ここで撤去モードの切り替え、建物の回転、配置時の自動従業員割り当てができます。撤去するとその建物の配置も解除されるため、大規模な変更後は人員を見直してください。"
    m_Metadata:
      m_Items: []
  - m_Id: 12960301203456
    m_Localized: "\u3053\u308C\u306F\u5009\u5EAB\u30D1\u30CD\u30EB\u3067\u3059\u3002\u73FE\u5728\u6240\u6301\u3057\u3066\u3044\u308B\u8CC7\u6E90\u306E\u5728\u5EAB\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 13340426780672
    m_Localized: "資源にはカテゴリがあるので、上段のカテゴリボタンで一覧を絞り込めます。"
    m_Metadata:
      m_Items: []
  - m_Id: 17836750028800
    m_Localized: "発注パネルです。取引先が資源を求めたら契約を承諾し、期限内に指定数量を納品します。"
    m_Metadata:
      m_Items: []
  - m_Id: 17928651423744
    m_Localized: "市場・企業・政府で絞り込めます。一般的にその順で規模が大きくなり、会社の資産でも変動します。"
    m_Metadata:
      m_Items: []
  - m_Id: 18539786682368
    m_Localized: "この切り替えで、進行中の受諾発注だけを表示できます。"
    m_Metadata:
      m_Items: []
  - m_Id: 18834268766208
    m_Localized: "ここでクライアントを選ぶと、右側にそのクライアントの発注が出ます。"
    m_Metadata:
      m_Items: []
  - m_Id: 19061579071488
    m_Localized: "新しい発注はここです。クリックで受諾し、期限内に資源を納品します。"
    m_Metadata:
      m_Items: []
  - m_Id: 19716532224000
    m_Localized: "\u3053\u308C\u306F\u5E02\u5834\u30D1\u30CD\u30EB\u3067\u3059\u3002\u8CC7\u6E90\u306E\u58F2\u8CB7\u3084\u7AF6\u5408\u4ED6\u793E\u306E\u60C5\u5831\u3092\u78BA\u8A8D\u3067\u304D\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 22018345287680
    m_Localized: "\u3053\u306E\u30DC\u30BF\u30F3\u3067\u8CC7\u6E90\u30D3\u30E5\u30FC\u3068\u30C8\u30EC\u30FC\u30C0\u30FC\uFF08\u7AF6\u5408\uFF09\u30D3\u30E5\u30FC\u3092\u5207\u308A\u66FF\u3048\u3089\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 22020337582080
    m_Localized: "\u3053\u308C\u306F\u8CC7\u6E90\u30D3\u30E5\u30FC\u3067\u3059\u3002\u73FE\u5728\u306E\u8CC7\u6E90\u306E\u8CB7\u3044\u5165\u308C\u30FB\u58F2\u5374\u91CF\u3092\u8ABF\u6574\u3067\u304D\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 24215317528576
    m_Localized: "\u8CC7\u6E90\u306E\u8A73\u7D30\u306F\u3053\u3053\u306B\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 24483870425088
    m_Localized: "\u8CC7\u6E90\u306E\u4FA1\u683C\u5C65\u6B74\u304C\u30B0\u30E9\u30D5\u3067\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 24698149027840
    m_Localized: "\u3053\u308C\u306F\u30C8\u30EC\u30FC\u30C0\u30FC\uFF08\u7AF6\u5408\uFF09\u30D3\u30E5\u30FC\u3067\u3059\u3002\u5404\u30C8\u30EC\u30FC\u30C0\u30FC\u306E\u60C5\u5831\u3092\u78BA\u8A8D\u3067\u304D\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 36510642880512
    m_Localized: "\u5F93\u696D\u54E1\u3092\u7BA1\u7406\u3059\u308B\u30D1\u30CD\u30EB\u3067\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 36904429305856
    m_Localized: "\u73FE\u5728\u306E\u30DE\u30CD\u30B8\u30E1\u30F3\u30C8\u80FD\u529B\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002\u5F93\u696D\u54E1\u6570\u306B\u5BFE\u3057\u3066\u4E00\u5B9A\u6570\u306E\u30DE\u30CD\u30FC\u30B8\u30E3\u30FC\u304C\u5FC5\u8981\u3067\u3001\u4E0D\u8DB3\u3059\u308B\u3068\u6E80\u8DB3\u5EA6\u304C\u4E0B\u304C\u308A\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 37440536854528
    m_Localized: "\u5F93\u696D\u54E1\u306E\u6E80\u8DB3\u5EA6\u306F\u69D8\u3005\u306A\u8981\u56E0\u3067\u5909\u308F\u308A\u307E\u3059\u3002\u4F55\u304C\u5F71\u97FF\u3057\u3066\u3044\u308B\u304B\u306F\u3053\u3053\u3067\u78BA\u8A8D\u3067\u304D\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 37828904239104
    m_Localized: "\u5F93\u696D\u54E1\u306E\u52B9\u7387\u306F\u6E80\u8DB3\u5EA6\u3067\u5909\u308F\u308A\u3001\u305D\u306E\u52B9\u7387\u306F\u5EFA\u7269\u306E\u4F5C\u696D\u901F\u5EA6\u3068\u751F\u7523\u91CF\u306B\u76F4\u63A5\u5F71\u97FF\u3057\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 38302378246144
    m_Localized: "\u6E80\u8DB3\u5EA6\u3092\u4E0A\u3052\u308B\u4E00\u756A\u306E\u65B9\u6CD5\u306F\u8CC3\u91D1\u30A2\u30C3\u30D7\u3067\u3059\u3002\u4E0B\u3052\u308B\u3068\u6E80\u8DB3\u5EA6\u306F\u4E0B\u304C\u308A\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 39086448852992
    m_Localized: "役割は4つ。ワーカーとテクニシャンは建物に配置、研究者はRP、マネージャーは管理不足のペナルティを防ぎます。"
    m_Metadata:
      m_Items: []
  - m_Id: 39688935456768
    m_Localized: "\u3053\u3053\u3067\u5F93\u696D\u54E1\u306E\u96C7\u7528\u30FB\u89E3\u96C7\u3092\u6C7A\u3081\u3089\u308C\u307E\u3059\u3002\u96C7\u7528\u30FB\u89E3\u96C7\u306B\u306F\u30AF\u30EC\u30B8\u30C3\u30C8\u304C\u304B\u304B\u308A\u3001\u89E3\u96C7\u3059\u308B\u3068\u6E80\u8DB3\u5EA6\u304C\u4E0B\u304C\u308A\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2561770013474816
    m_Localized: "\u3053\u308C\u306F\u7814\u7A76\u30D1\u30CD\u30EB\u3067\u3059\u3002\u5EFA\u7269\u306E\u89E3\u653E\u3084\u751F\u7523\u6027\u30A2\u30C3\u30D7\u304C\u53EF\u80FD\u306B\u306A\u308A\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2562082698838016
    m_Localized: "\u7814\u7A76\u30DD\u30A4\u30F3\u30C8\uFF08RP\uFF09\u30681\u65E5\u3042\u305F\u308A\u306E\u7372\u5F97\u91CF\u304C\u3053\u3053\u306B\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2562316594200576
    m_Localized: "\u7814\u7A76\u8005\u306E\u6570\u3068\u53D7\u3051\u3066\u3044\u308B\u52B9\u679C\u3092\u78BA\u8A8D\u3067\u304D\u308B\u30D1\u30CD\u30EB\u3067\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2562738453102592
    m_Localized: "研究ツリーです。完了したノードは色分けされ、前提を満たすと次の接続先が解放されます。"
    m_Metadata:
      m_Items: []
  - m_Id: 2563160425250816
    m_Localized: "\u3053\u308C\u306F\u8CA1\u52D9\u30D1\u30CD\u30EB\u3067\u3059\u3002\u4F1A\u793E\u306E\u6210\u9577\u306E\u63A8\u79FB\u3092\u78BA\u8A8D\u3067\u304D\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2564533472608256
    m_Localized: "\u73FE\u5728\u306E\u6708\u9593\u6210\u9577\u7387\u3092\u8868\u793A\u3057\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2565297930649600
    m_Localized: "\u73FE\u5728\u306E\u6708\u9593\u5229\u76CA\u3092\u8868\u793A\u3057\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2566859943985152
    m_Localized: "\u73FE\u5728\u306E\u4F01\u696D\u4FA1\u5024\u3092\u30B0\u30E9\u30D5\u3067\u8868\u793A\u3057\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2566981499109376
    m_Localized: "\u73FE\u5728\u306E\u30AF\u30EC\u30B8\u30C3\u30C8\u3092\u30B0\u30E9\u30D5\u3067\u8868\u793A\u3057\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000000
    m_Localized: "\u52B4\u50CD\u7D44\u5408\u30C1\u30E3\u30D7\u30BF\u30FC\u3092\u7BA1\u7406\u3059\u308B\u30D1\u30CD\u30EB\u3067\u3059\u3002\u9032\u884C\u4E2D\u306F\u7DCF\u5408\u6E80\u8DB3\u5EA6\u306B\u3088\u308A\u6BCE\u65E5\u7D50\u5408\u5EA6\u304C\u5897\u6E1B\u3057\u3001\u8981\u6C42\u3092\u6E80\u305F\u3059\u3068\u7D50\u5408\u5EA6\u30DC\u30FC\u30CA\u30B9\u3092\u5F97\u3089\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000001
    m_Localized: "\u30A2\u30A4\u30B3\u30F3\u3068\u6570\u5B57\u306F\u30C1\u30E3\u30D7\u30BF\u30FC\u306E\u6B8B\u308A\u65E5\u6570\u3067\u3059\u30020\u306B\u306A\u308B\u3068\u30CE\u30BE\u30A4\u30D9\u30F3\u30C8\u304C\u7D42\u4E86\u3057\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000002
    m_Localized: "\u52A0\u91CD\u5E73\u5747\u6E80\u8DB3\u5EA6\u306B\u3088\u308B\u6B21\u65E5\u306E\u65E5\u6B21\u7D50\u5408\u5EA6\u5909\u5316\u3092\u898B\u3053\u307E\u3059\u3002\u5DE6\u306F\u57FA\u6E96\u4EE5\u4E0A\u3067\u5DE6\u2192\u53F3\u306B\u5897\u52A0\u3001\u53F3\u306F\u57FA\u6E96\u672A\u6E80\u3067\u53F3\u2192\u5DE6\u306B\u6E1B\u5C11\u3092\u793A\u3057\u307E\u3059\u3002\u6570\u5024\u306F1\u65E5\u3042\u305F\u308A\u306E\u5909\u5316\u7387(%)\u3067\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000003
    m_Localized: "\u7D50\u5408\u5EA6\u306F0\u301C100%\u306E\u30A4\u30D9\u30F3\u30C8\u6307\u6A19\u3067\u3059\u3002\u4E0A\u306E\u30D0\u30FC\u306B\u5F93\u3063\u3066\u6BCE\u65E5\u81EA\u52D5\u66F4\u65B0\u3055\u308C\u3001100%\u3067\u30C1\u30E3\u30D7\u30BF\u30FC\u5B8C\u4E86\u3067\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000004
    m_Localized: "\u8077\u7A2E\u5225\u306E\u6E80\u8DB3\u5EA6\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002\u7D66\u4E0E\u8ABF\u6574\u3001\u5927\u898F\u6A21\u89E3\u96C7\u306E\u81EA\u5236\u3001\u30CE\u30BE\u8981\u6C42\u306E\u5B9F\u884C\u304C\u65E5\u6B21\u30D0\u30FC\u3068\u7D50\u5408\u5EA6\u3092\u52D5\u304B\u3059\u4E3B\u306A\u624B\u6BB5\u3067\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000005
    m_Localized: "\u30A2\u30AF\u30C6\u30A3\u30D6\u306A\u30CE\u30BE\u8981\u6C42\u3067\u3059\u3002\u5404\u8981\u6C42\u306F\u30AF\u30EC\u30B8\u30C3\u30C8\u30FB\u8CC7\u6E90\u30FB\u653F\u7B56\u306E\u3046\u30611\u3064\u3068\u671F\u9650\u65E5\u6570\u3092\u6301\u3061\u307E\u3059\u3002\u6761\u4EF6\u3092\u6E80\u305F\u3059\u3068\u884C\u304C\u5F37\u8ABF\u3055\u308C\u3001\u30BF\u30C3\u30D7\u3067\u5B8C\u4E86\u3057\u7D50\u5408\u5EA6\u5831\u916C\u3092\u53D7\u3051\u53D6\u308C\u307E\u3059\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000000
    m_Localized: "政策パネルです。職場ルールを切り替え、生産・コスト・満足度に継続効果を与えます。"
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000001
    m_Localized: "各政策をオン・オフできます。クレジットやRPが必要なものや、数か月限定のものもあるので内容を確認してください。"
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000002
    m_Localized: "有効な政策と効果がここにまとまります。工場にかかっているボーナスとペナルティを一覧できます。"
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000000
    m_Localized: "ニュースパネルです。市場の変化やメインイベントなど、進行に合わせたヘッドラインが届きます。"
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000001
    m_Localized: "ここでストーリーをスクロールします。条件で新記事が追加され、期限で消えます。"
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000002
    m_Localized: "見出しを開くと本文が読めます。価格・ノゾ・研究のヒントになることが多いので、大きな変化の後に確認してください。"
    m_Metadata:
      m_Items: []
