    m_Metadata:
      m_Items: []
  - m_Id: 864226269003
    m_Localized: "\uB300\uB959 \uBC29\uC704\uAD70"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269004
    m_Localized: "\uC804\uC790 \uC81C\uC870 \uD68C\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269005
    m_Localized: "\uC815\uC608 \uBCD1\uAE30 \uADF8\uB8F9"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269006
    m_Localized: "\uC815\uC608 \uACBD\uBE44 \uBD80\uB300"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269007
    m_Localized: "\uD328\uC158 \uB9AC\uD14C\uC77C \uCCB4\uC778"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269008
    m_Localized: "\uAC1C\uCC99\uC9C0 \uC81C\uC7AC\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269009
    m_Localized: "\uB300\uB959 \uC790\uC6D0 \uC2E0\uB514\uCF00\uC774\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269010
    m_Localized: "\uC81C\uAD6D \uBB3C\uB958\uAD6D"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269011
    m_Localized: "\uC0B0\uC5C5 \uC911\uAC1C \uB124\uD2B8\uC6CC\uD06C"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269012
    m_Localized: "\uCCA0\uAD11\uC0B0 \uCEE8\uC18C\uC2DC\uC5C4"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269013
    m_Localized: "\uBAA9\uC7AC \uCEE8\uC18C\uC2DC\uC5C4"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269014
    m_Localized: "\uACE0\uAE09 \uAC00\uAD6C \uC1FC\uB8F8"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269015
    m_Localized: "\uAD70\uC6A9 \uBCD1\uAE30\uCC3D"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269016
    m_Localized: "\uAD6D\uAC00 \uAC70\uB798\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269017
    m_Localized: "\uBD81\uD48D \uC0B0\uC5C5 \uC5F0\uD569"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269018
    m_Localized: "\uC815\uBC00 \uBD80\uD488 \uC8FC\uC2DD\uD68C\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269019
    m_Localized: "\uC815\uBC00 \uBCD1\uAE30 \uACF5\uBC29"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269020
    m_Localized: "\uD504\uB9AC\uBBF8\uC5C4 \uC0B0\uC5C5 \uBB3C\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269021
    m_Localized: "\uC81C\uB828 \uC870\uD569"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269022
    m_Localized: "\uC120\uBD09 \uC81C\uCCA0\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269023
    m_Localized: "\uD478\uB978 \uB300\uB959 \uAC70\uB798\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269024
    m_Localized: "\uC678\uAD50\uBD80"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269025
    m_Localized: "\uC81C\uAD6D \uC544\uCE74\uB370\uBBF8"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269026
    m_Localized: "\uC81C\uAD6D \uADFC\uC704\uB300"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269027
    m_Localized: "\uC81C\uAD6D \uC7AC\uBB34\uBD80"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269028
    m_Localized: "\uAD70\uC218 \uC870\uB2EC\uCCAD"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269029
    m_Localized: "\uACF5\uACF5\uC0AC\uC5C5\uBD80"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269030
    m_Localized: "\uC655\uC2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269031
    m_Localized: "\uAD6D\uACE0 \uC900\uBE44\uAE08"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269032
    m_Localized: "\uC608\uC220 \uC218\uC9D1\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269033
    m_Localized: "\uC0B0\uC5C5 \uD22C\uC790\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269034
    m_Localized: "\uC7A5\uC778 \uB300\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269035
    m_Localized: "\uC0C1\uC778 \uAE38\uB4DC"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269036
    m_Localized: "\uADC0\uC871 \uC601\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269037
    m_Localized: "\uC0AC\uC801 \uC218\uC9D1\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269038
    m_Localized: "\uD559\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269039
    m_Localized: "\uBD80\uC720\uD55C \uC0C1\uC778"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269040
    m_Localized: "\uBB34\uAE30 \uC560\uD638\uAC00"
    m_Metadata:
      m_Items: []
  - m_Id: 864226269101
    m_Localized: "\uACE0\uAE09 \uBAA9\uC7AC\uB97C \uB7ED\uC154\uB9AC \uBD80\uB3D9\uC0B0\uC6A9
      \uB9DE\uCDA4 \uAC00\uAD6C\uC640 \uAC74\uCD95 \uC694\uC18C\uB85C \uB9CC\uB4DC\uB294
      \uC7A5\uC778\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269102
    m_Localized: "\uBBFC\uAC04\xB7\uC815\uBD80 \uC2DC\uC7A5\uC6A9 \uC790\uB3D9\uCC28,
      \uD2B8\uB7ED, \uAD70\uC6A9 \uCC28\uB7C9\uC744 \uC0DD\uC0B0\uD558\uB294 \uC8FC\uC694
      \uC790\uB3D9\uCC28 \uC81C\uC870\uC0AC."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269104
    m_Localized: "\uC0B0\uC5C5\xB7\uC18C\uBE44\uC790 \uC2DC\uC7A5\uC6A9 \uBAA8\uD130,
      \uC804\uAD6C, \uBC30\uC120\uC744 \uC0DD\uC0B0\uD558\uB294 \uC8FC\uC694 \uC804\uC790
      \uC81C\uC870\uC0AC."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269105
    m_Localized: "\uAD70\uB300\uC640 \uACBD\uBE44 \uBD80\uB300\uC5D0 \uACE0\uAE09
      \uAC15\uCCA0, \uAE08, \uCCA8\uB2E8 \uBB34\uAE30\uB97C \uACF5\uAE09\uD558\uB294
      \uC77C\uB958 \uBCD1\uAE30 \uCF69\uAE00\uB85C\uBA38\uB9BF."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269107
    m_Localized: "\uC77C\uBC18 \uC18C\uBE44\uC790\uC640 \uB7ED\uC154\uB9AC \uC2DC\uC7A5\uC744
      \uC704\uD574 \uAE30\uBCF8\uBD80\uD130 \uACE0\uAE09 \uD328\uC158\uAE4C\uC9C0
      \uC81C\uACF5\uD558\uB294 \uC804\uAD6D \uC758\uB958 \uC18C\uB9E4 \uCCB4\uC778."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269108
    m_Localized: "\uAC00\uACF5 \uBAA9\uC7AC\uC640 \uAC00\uAD6C\uB97C \uC2DC\uC7A5\uC5D0
      \uC3DF\uC544 \uBD93\uACE0, \uACF5\uAE09\uCC98\uC5D0\uC11C \uC6D0\uBAA9\uC744
      \uB300\uB7C9 \uAD6C\uB9E4\uD558\uB294 \uAC1C\uCC99\uC9C0 \uC81C\uC7AC\uC18C."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269109
    m_Localized: "\uC81C\uAD6D \uC804\uC5ED\uC5D0\uC11C \uADC0\uAE08\uC18D, \uACE0\uAE09
      \uBAA9\uC7AC, \uC815\uC81C \uC789\uACF3\uC744 \uBAA8\uC544 \uC815\uBD80\xB7\uAE30\uC5C5
      \uACC4\uC57D\uC5D0 \uACF5\uAE09\uD558\uB294 \uBB34\uC5ED\uC5C5\uCCB4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269110
    m_Localized: "\uC81C\uAD6D\uC758 \uC911\uC559 \uC720\uD1B5\uB9DD. \uAC01 \uC9C0\uC5ED
      \uAC04 \uD544\uC218 \uC790\uC6D0\uC758 \uD750\uB984\uC744 \uC870\uC728\uD558\uACE0
      \uC81C\uAD6D \uC791\uC804\uC6A9 \uC804\uB7B5 \uBE44\uCD95\uC744 \uC720\uC9C0\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269111
    m_Localized: "\uC0B0\uC5C5\xB7\uAD70\uC0AC \uACE0\uAC1D\uC744 \uC704\uD574 \uAE08\uC18D,
      \uB3C4\uAD6C, \uBB34\uAE30\uB97C \uACF5\uAE09\uD558\uB294 \uC815\uAD50\uD55C
      \uAC70\uB798 \uB124\uD2B8\uC6CC\uD06C."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269112
    m_Localized: "\uAE4A\uC740 \uAC31\uB3C4\uC758 \uCE74\uB974\uD154. \uC800\uB834\uD55C
      \uAD11\uC11D\uC73C\uB85C \uC2DC\uC7A5\uC744 \uCC44\uC6B0\uACE0 \uBB34\uC790\uBE44\uD55C
      \uD6A8\uC728\uB85C \uACBD\uC7C1\uC0AC\uB97C \uBC00\uC5B4\uB0B8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269113
    m_Localized: "\uBD81\uBD80 \uBCC0\uACBD\uC758 \uBAA9\uC7AC \uC218\uCD9C \uB300\uBD80\uBD84\uC744
      \uC7A5\uC545\uD55C \uBC8C\uBAA9\uC5C5\uC790\uB4E4\uC758 \uAD11\uBC94\uC704\uD55C
      \uC5F0\uD569."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269114
    m_Localized: "\uBD80\uC720\uD55C \uACE0\uAC1D\uACFC \uB7ED\uC154\uB9AC \uBD80\uB3D9\uC0B0\uC744
      \uC704\uD55C \uACE0\uAE09\xB7\uB9DE\uCDA4 \uAC00\uAD6C\uB97C \uC804\uBB38\uC73C\uB85C
      \uD558\uB294 \uACE0\uAE09 \uAC00\uAD6C \uC18C\uB9E4\uC810."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269115
    m_Localized: "\uC218\uB3C4 \uAD70\uC6A9 \uACF5\uC7A5. \uAD70\uC6A9\uAE09 \uBB34\uAE30\uC640
      \uC7A5\uBE44\uB97C \uADDC\uC728 \uC788\uAC8C \uC0DD\uC0B0\uD558\uC5EC \uAD70\uB300\uC5D0
      \uACF5\uAE09\uD558\uB294 \uAC83\uC73C\uB85C \uC720\uBA85\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269116
    m_Localized: "\uC815\uBD80 \uACF5\uC778 \uBE0C\uB85C\uCEE4. \uC5C4\uACA9\uD788
      \uADDC\uC81C\uB41C \uACBD\uB9E4\uB97C \uD1B5\uD574 \uC218\uB3C4\uC5D0 \uBAA9\uC7AC,
      \uAD11\uC11D, \uACE0\uAE09\uD488 \uACF5\uAE09\uC744 \uC870\uC808\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269117
    m_Localized: "\uB0B4\uB959 \uACF5\uC7A5\uC5D0 \uB3C4\uAD6C\uC640 \uD569\uAE08\uC744
      \uB300\uB7C9 \uC0DD\uC0B0\uD558\uBA74\uC11C \uCCA0\uACFC \uBAA9\uC7AC\uB97C
      \uD761\uC218\uD558\uB294 \uC911\uACF5\uC5C5 \uAC70\uBB3C\uB4E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269118
    m_Localized: "\uC0B0\uC5C5 \uAE30\uACC4\xB7\uCC28\uB7C9\uC6A9 \uC815\uBC00 \uAE30\uC5B4,
      \uBCFC\uD2B8, \uAE30\uACC4 \uBD80\uD488\uC744 \uC0DD\uC0B0\uD558\uB294 \uC804\uBB38
      \uC81C\uC870\uC0AC."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269119
    m_Localized: "\uC815\uBC00 \uC81C\uC791 \uBB34\uAE30\uB85C \uC720\uBA85\uD55C
      \uBD80\uD2F0\uD06C \uACF5\uBC29. \uAC00\uC7A5 \uC21C\uC218\uD55C \uAE08\uC18D\uACFC
      \uACE0\uAE09 \uBAA9\uC7AC\uB9CC \uC870\uB2EC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269120
    m_Localized: "\uC0B0\uC5C5 \uC2DC\uC124\xB7\uAD70\uC0AC \uC6A9\uC5ED\uC5C5\uCCB4\uB97C
      \uC704\uD574 \uACE0\uAE09 \uAE08\uC18D, \uB3C4\uAD6C, \uBB34\uAE30 \uC870\uB2EC\uC744
      \uC804\uBB38\uC73C\uB85C \uD558\uB294 \uACE0\uAE09 \uBB3C\uB958 \uD68C\uC0AC."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269121
    m_Localized: "\uAD11\uC11D \uC0B0\uC744 \uC789\uACF3\uC73C\uB85C \uC815\uC81C\uD558\uC5EC
      \uB3C4\uC2DC \uC81C\uB828\uC18C\uC5D0 \uC5F0\uC911 \uACF5\uAE09\uD558\uB294
      \uD611\uB3D9 \uC81C\uB828\uC18C."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269122
    m_Localized: "\uACE0\uAE09 \uAD11\uC11D\uC744 \uAD6D\uAC00 \uAD70\uC0AC\xB7\uAC74\uC124
      \uC0B0\uC5C5\uC6A9 \uBBFF\uC74C\uC9C1\uD55C \uAC15\uCCA0\uB85C \uBC14\uAFB8\uB294
      \uADDC\uC728 \uC788\uB294 \uC81C\uCCA0\uC18C."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269123
    m_Localized: "\uBAA9\uC218\uB4E4\uC5D0\uAC8C \uB4F1\uAE09\uBCC4 \uBAA9\uC7AC\uC640
      \uBBFC\uBCD1\uB300\uC6A9 \uAE30\uBCF8 \uBB34\uAE30\uB97C \uACF5\uAE09\uD558\uB294
      \uC9C0\uC5ED \uB3C4\uB9E4\uC5C5\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269124
    m_Localized: "\uC678\uAD50 \uC11C\uBE44\uC2A4\uB294 \uACF5\uC2DD \uC758\uC2DD,
      \uAD6D\uBE48 \uBC29\uBB38, \uC678\uAD6D \uADC0\uBE48\uC5D0\uAC8C \uC904 \uC678\uAD50
      \uC120\uBB3C\uC744 \uC704\uD574 \uB7ED\uC154\uB9AC \uC0C1\uD488, \uACE0\uAE09
      \uAC00\uAD6C, \uADC0\uAE08\uC18D\uC774 \uD544\uC694\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269125
    m_Localized: "\uC81C\uAD6D\uC758 \uCD5C\uACE0 \uC5F0\uAD6C\xB7\uAD50\uC721 \uAE30\uAD00\uC73C\uB85C,
      \uACFC\uD559 \uC2E4\uD5D8\uACFC \uC5F0\uAD6C\uB97C \uC704\uD574 \uC804\uC790
      \uBD80\uD488, \uC815\uBC00 \uB3C4\uAD6C, \uB2E4\uC591\uD55C \uC7AC\uB8CC\uAC00
      \uD544\uC694\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269126
    m_Localized: "\uC218\uB3C4\uB97C \uBCF4\uD638\uD558\uB294 \uC815\uC608 \uACBD\uBE44
      \uBD80\uB300. \uC21C\uCC30\uACFC \uACBD\uBE44 \uC791\uC804\uC744 \uC704\uD574
      \uC18C\uD615 \uBB34\uAE30, \uD0C4\uC57D, \uCC28\uB7C9\uC774 \uD544\uC694\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269127
    m_Localized: "\uC81C\uAD6D\uC758 \uC911\uC559 \uC7AC\uBB34\uBD80\uB85C \uAD6D\uAC00
      \uC7AC\uC815\uC744 \uAD00\uB9AC\uD558\uACE0 \uBAA8\uB4E0 \uC9C0\uC5ED\uC758
      \uC81C\uAD6D \uC791\uC804\uC744 \uC704\uD55C \uC790\uC6D0\uC744 \uC870\uB2EC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269128
    m_Localized: "\uC81C\uAD6D \uAD70\uB300\uC5D0 \uBB34\uAE30, \uCC28\uB7C9, \uAD70\uC6A9
      \uC7A5\uBE44\uB97C \uACF5\uAE09\uD558\uAE30 \uC704\uD574 \uC870\uB2EC\uD558\uB294
      \uC815\uBD80 \uAE30\uAD00."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269129
    m_Localized: "\uC778\uD504\uB77C \uD504\uB85C\uC81D\uD2B8\uB97C \uB2F4\uB2F9\uD558\uB294
      \uC815\uBD80 \uAE30\uAD00\uC73C\uB85C, \uB3C4\uB85C, \uB2E4\uB9AC, \uACF5\uACF5
      \uAC74\uBB3C\uC744 \uC704\uD574 \uAE08\uC18D, \uBAA9\uC7AC, \uB3C4\uAD6C\uB97C
      \uC9C0\uC18D\uC801\uC73C\uB85C \uC870\uB2EC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269130
    m_Localized: "\uC655\uC2E4\uC740 \uD654\uB824\uD55C \uC0DD\uD65C \uBC29\uC2DD\uC744
      \uC720\uC9C0\uD558\uBA70, \uC758\uC2DD\uACFC \uBD80\uC758 \uACFC\uC2DC\uB97C
      \uC704\uD574 \uB7ED\uC154\uB9AC \uC0C1\uD488, \uACE0\uAE09 \uAC00\uAD6C, \uADC0\uAE08\uC18D\uC744
      \uB04A\uC784\uC5C6\uC774 \uD68D\uB4DD\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269131
    m_Localized: "\uC81C\uAD6D\uC758 \uC804\uB7B5 \uBE44\uCD95\uC73C\uB85C, \uC7AC\uC815
      \uC548\uC815\uC744 \uC720\uC9C0\uD558\uACE0 \uC81C\uAD6D \uD1B5\uD654\uB97C
      \uB4B7\uBC1B\uCE68\uD558\uAE30 \uC704\uD574 \uADC0\uAE08\uC18D\uACFC \uAE08\uC744
      \uCD95\uC801\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269132
    m_Localized: "\uBBF8\uC220\uACFC \uACF5\uC608\uD488\uC744 \uC5F4\uC815\uC801\uC73C\uB85C
      \uC218\uC9D1\uD558\uB294 \uC0AC\uB78C\uC73C\uB85C, \uAD11\uBC94\uC704\uD55C
      \uCEEC\uB809\uC158\uC744 \uC704\uD574 \uACE0\uAE09 \uAC00\uAD6C, \uB7ED\uC154\uB9AC
      \uC758\uB958, \uACE0\uAE09 \uBAA9\uC7AC\uB97C \uCC3E\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269133
    m_Localized: "\uC0B0\uC5C5 \uBCA4\uCC98\uC5D0 \uC790\uAE08\uC744 \uD22C\uC790\uD558\uB294
      \uBD80\uC720\uD55C \uD22C\uC790\uC790\uB85C, \uB2E4\uC591\uD55C \uC81C\uC870
      \uD504\uB85C\uC81D\uD2B8\uC640 \uACF5\uC7A5\uC744 \uC9C0\uC6D0\uD558\uAE30
      \uC704\uD574 \uAE08\uC18D, \uBD80\uD488, \uB3C4\uAD6C\uB97C \uAD6C\uB9E4\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269134
    m_Localized: "\uACE0\uAE09 \uACF5\uC608\uB97C \uC804\uBB38\uC73C\uB85C \uD558\uB294
      \uC720\uBA85\uD55C \uC7A5\uC778\uC73C\uB85C, \uB9DE\uCDA4 \uC81C\uC791\uC744
      \uC704\uD574 \uACE0\uAE09 \uBAA9\uC7AC, \uC815\uBC00 \uB3C4\uAD6C, \uACE0\uD488\uC9C8
      \uC7AC\uB8CC\uB97C \uC9C0\uC18D\uC801\uC73C\uB85C \uC870\uB2EC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269135
    m_Localized: "\uC790\uC6D0\uC744 \uBAA8\uC544 \uBB34\uC5ED\uB85C\uC640 \uC2DC\uC7A5
      \uC804\uC5ED\uC5D0 \uBC30\uD3EC\uD558\uAE30 \uC704\uD574 \uB2E4\uC591\uD55C
      \uC0C1\uD488\uC744 \uAD6C\uB9E4\uD558\uB294 \uAC15\uB825\uD55C \uBB34\uC5ED
      \uD611\uD68C."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269136
    m_Localized: "\uC870\uC0C1 \uB300\uB300\uB85C \uB0B4\uB824\uC628 \uC601\uC9C0\uB97C
      \uC720\uC9C0\uD558\uB294 \uBA85\uB9DD \uC788\uB294 \uADC0\uC871 \uAC00\uBB38\uC73C\uB85C,
      \uD654\uB824\uD55C \uC0DD\uD65C \uBC29\uC2DD\uC744 \uC704\uD574 \uACE0\uAE09
      \uAC00\uAD6C, \uB7ED\uC154\uB9AC \uC0C1\uD488, \uACE0\uAE09 \uC7AC\uB8CC\uAC00
      \uD544\uC694\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269137
    m_Localized: "\uAE4A\uC740 \uC8FC\uBA38\uB2C8\uB97C \uAC00\uC9C4 \uAE30\uC774\uD55C
      \uC218\uC9D1\uAC00\uB85C, \uC0AC\uC801 \uCEEC\uB809\uC158\uC744 \uC704\uD574
      \uADC0\uAE08\uC18D, \uACE0\uAE09 \uBAA9\uC7AC, \uB3C5\uD2B9\uD55C \uBD80\uD488\uC744
      \uD3EC\uD568\uD55C \uD76C\uADC0\uD558\uACE0 \uAC00\uCE58 \uC788\uB294 \uC790\uC6D0\uC744
      \uCC3E\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269138
    m_Localized: "\uC5F0\uAD6C\uB97C \uC218\uD589\uD558\uB294 \uD559\uC2DD \uC788\uB294
      \uD559\uC790\uB85C, \uC2E4\uD5D8\uACFC \uD559\uC220 \uC791\uC5C5\uC744 \uC704\uD574
      \uC804\uC790 \uBD80\uD488, \uC815\uBC00 \uB3C4\uAD6C, \uAE30\uBCF8 \uC7AC\uB8CC\uAC00
      \uD544\uC694\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269139
    m_Localized: "\uAD11\uBC94\uC704\uD55C \uBB34\uC5ED \uB124\uD2B8\uC6CC\uD06C\uB97C
      \uAC00\uC9C4 \uBC88\uC601\uD558\uB294 \uC0C1\uC778\uC73C\uB85C, \uC81C\uAD6D
      \uC804\uC5ED\uC758 \uAC1C\uC778 \uBCA4\uCC98\uC640 \uD22C\uC790\uB97C \uC704\uD574
      \uB2E4\uC591\uD55C \uC790\uC6D0\uC744 \uAD6C\uB9E4\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269140
    m_Localized: "\uAD70\uC6A9 \uBB34\uAE30\uC758 \uC0AC\uC801 \uC218\uC9D1\uAC00\uC774\uC790
      \uC560\uD638\uAC00\uB85C, \uC0AC\uC801 \uBB34\uAE30\uACE0\uB97C \uC704\uD574
      \uC18C\uD615 \uBB34\uAE30, \uC911\uD654\uAE30, \uD0C4\uC57D\uC744 \uB04A\uC784\uC5C6\uC774
      \uD68D\uB4DD\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 864226269041
    m_Localized: 플레이어 기업
    m_Metadata:
      m_Items: []
  - m_Id: 864226269141
    m_Localized: 플레이어가 직접 운영하는 기업.
    m_Metadata:
      m_Items: []
  - m_Id: 864226263054
    m_Localized: "\uC815\uBD80"
    m_Metadata:
      m_Items: []
  - m_Id: 864226263055
    m_Localized: "\uAE30\uC5C5"
    m_Metadata:
      m_Items: []
  - m_Id: 864226263056
    m_Localized: "\uAC1C\uC778"
    m_Metadata:
      m_Items: []
