  m_SharedData: {fileID: 11400000, guid: e00198e87a257ff41b02cc989c3a409a, type: 2}
  m_Metadata:
    m_Items:
    - rid: 2319839819189715043
  m_TableData:
  - m_Id: 11264212992
    m_Localized: "\uD32C\uD1A0\uB9AC\uC5D0 \uC624\uC2E0 \uAC83\uC744 \uD658\uC601\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items:
      - rid: 2319839819189715043
  - m_Id: 438890283008
    m_Localized: "\uACF5\uC7A5 \uACBD\uC601 \uC2DC\uBBAC\uB808\uC774\uC158 \uAC8C\uC784\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 575934971904
    m_Localized: "\uAC01 \uBA54\uC778 \uD328\uB110\uC758 (?) \uBC84\uD2BC\uC73C\uB85C
      \uB3C4\uC6C0\uB9D0\uC744 \uB2E4\uC2DC \uC5F4 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1678642659328
    m_Localized: "\uC67C\uCABD \uC704\uC5D0 \uD06C\uB808\uB527\uACFC \uC5F0\uAD6C
      \uD3EC\uC778\uD2B8\uAC00 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2291514359808
    m_Localized: "\uC9C1\uC6D0 \uC218, \uBC30\uCE58, \uB9CC\uC871\uB3C4\uAC00 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2320476028928
    m_Localized: "\uB0A0\uC9DC\xB7\uC2DC\uAC01, \uD29C\uD1A0\uB9AC\uC5BC, \uC124\uC815
      \uBC84\uD2BC\uC774 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2777508364288
    m_Localized: "\uC800\uC7A5\uC18C\xB7\uBC1C\uC8FC\xB7\uC2DC\uC7A5\xB7\uC9C1\uC6D0\xB7\uC5F0\uAD6C\xB7\uB274\uC2A4\xB7\uC7AC\uBB34
      \uD328\uB110 \uB2E8\uCD95 \uC544\uC774\uCF58\uC785\uB2C8\uB2E4. F1~F9\uB3C4
      \uC0AC\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 5943566155776
    m_Localized: "\uC544\uB798 \uAC74\uBB3C \uD328\uB110\uC5D0\uC11C \uACF5\uC7A5\uC744
      \uD655\uC7A5\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7203816095744
    m_Localized: "\uBE14\uB8E8\uD504\uB9B0\uD2B8 \uD0ED\uC5D0\uC11C \uBC30\uCE58\uB97C
      \uC800\uC7A5\uD574 \uB098\uC911\uC5D0 \uB2E4\uC2DC \uAE54 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7579063697408
    m_Localized: "\uAC74\uBB3C \uBC84\uD2BC\uC740 \uC6A9\uB3C4\uBCC4\uB85C \uBB36\uC5EC
      \uC788\uC2B5\uB2C8\uB2E4. \uC720\uD1B5\uC5D0\uB294 \uB3C4\uB85C, \uC2A4\uD50C\uB9AC\uD130,
      \uD130\uB110\uC774 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7894026567680
    m_Localized: "\uC5EC\uAE30\uC11C \uAC74\uBB3C\xB7\uB3C4\uB85C\uB97C \uACE0\uB978
      \uB4A4 \uADF8\uB9AC\uB4DC\uC5D0 \uBC30\uCE58\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8131256401920
    m_Localized: "\uD604\uC7AC \uC790\uC6D0 \uC218\uB7C9\uC774 \uC5EC\uAE30 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9056704413696
    m_Localized: "\uACF5\uC7A5\uC774 \uCEE4\uC9C0\uBA74 \uC2A4\uD50C\uB9AC\uD130\uC640
      \uD130\uB110\uB85C \uCC98\uB9AC\uB7C9\uC744 \uC548\uC815\uC2DC\uD0A4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 11779361357824
    m_Localized: "\uC81C\uAC70 \uBAA8\uB4DC\uC640 \uC790\uB3D9 \uBC30\uCE58 \uC2A4\uC704\uCE58\uAC00
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 12960301203456
    m_Localized: "\uC800\uC7A5\uC18C \uD328\uB110\uC785\uB2C8\uB2E4. \uBCF4\uC720
      \uC790\uC6D0 \uC218\uB7C9\uC774 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 13340426780672
    m_Localized: "\uC790\uC6D0\uB9C8\uB2E4 \uCE74\uD14C\uACE0\uB9AC\uAC00 \uC788\uC73C\uB2C8,
      \uC704\uCABD \uCE74\uD14C\uACE0\uB9AC \uBC84\uD2BC\uC73C\uB85C \uBAA9\uB85D\uC744
      \uC881\uD600 \uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 17836750028800
    m_Localized: "\uBC1C\uC8FC \uD328\uB110\uC785\uB2C8\uB2E4. \uACC4\uC57D\uC744
      \uC218\uB77D\uD558\uACE0 \uAE30\uD55C \uC548\uC5D0 \uC790\uC6D0\uC744 \uB0A9\uD488\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 17928651423744
    m_Localized: "\uC2DC\uC7A5\xB7\uAE30\uC5C5\xB7\uC815\uBD80 \uBC84\uD2BC\uC73C\uB85C
      \uBC1C\uC8FC \uC720\uD615\uC744 \uAC78\uB7EC \uB0C5\uB2C8\uB2E4. \uBCF4\uD1B5
      \uADF8 \uC21C\uC11C\uB85C \uADDC\uBAA8\uAC00 \uCEE4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 18539786682368
    m_Localized: "\uC774 \uC2A4\uC704\uCE58\uB97C \uCF1C\uBA74 \uC9C0\uAE08 \uC9C4\uD589
      \uC911\uC778 \uC218\uB77D \uBC1C\uC8FC\uB9CC \uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 18834268766208
    m_Localized: "\uC67C\uCABD\uC5D0\uC11C \uAC70\uB798\uCC98\uB97C \uACE0\uB974\uBA74
      \uC624\uB978\uCABD\uC5D0 \uADF8 \uAC70\uB798\uCC98\uC758 \uBC1C\uC8FC \uBAA9\uB85D\uC774
      \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 19061579071488
    m_Localized: "\uC0C8 \uACC4\uC57D\uC774 \uC5EC\uAE30\uC5D0 \uC313\uC785\uB2C8\uB2E4.
      \uD074\uB9AD\uD574 \uC218\uB77D\uD55C \uB4A4, \uAE30\uD55C \uC548\uC5D0 \uB0A9\uD488\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 19716532224000
    m_Localized: "\uC2DC\uC7A5 \uD328\uB110\uC785\uB2C8\uB2E4. \uC790\uC6D0 \uAC70\uB798\uC640
      \uACBD\uC7C1\uC0AC \uC815\uBCF4\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 22018345287680
    m_Localized: "\uC774 \uBC84\uD2BC\uC73C\uB85C \uC790\uC6D0 \uBCF4\uAE30\uC640
      \uAC70\uB798\uC790(\uACBD\uC7C1\uC0AC) \uBCF4\uAE30\uB97C \uC804\uD658\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 22020337582080
    m_Localized: "\uD604\uC7AC \uC790\uC6D0\uC758 \uAD6C\uB9E4\xB7\uD310\uB9E4\uB7C9\uC744
      \uC5EC\uAE30\uC11C \uC870\uC808\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24215317528576
    m_Localized: "\uC790\uC6D0 \uC815\uBCF4\uB294 \uC5EC\uAE30\uC5D0 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24483870425088
    m_Localized: "\uC790\uC6D0 \uAC00\uACA9 \uCD94\uC774\uAC00 \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24698149027840
    m_Localized: "\uAC01 \uAC70\uB798\uC790(\uACBD\uC7C1\uC0AC) \uC815\uBCF4\uB97C
      \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24812468024680
    m_Localized: "\uC2DC\uC7A5 \uD65C\uC6A9\uC774 \uC218\uC775\uC758 \uD575\uC2EC\uC785\uB2C8\uB2E4.
      \uAC00\uACA9 \uD750\uB984\uC744 \uBCF4\uACE0 \uC801\uC808\uD788 \uB9E4\uB9E4\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 36510642880512
    m_Localized: "\uC9C1\uC6D0\uC744 \uAD00\uB9AC\uD558\uB294 \uD328\uB110\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 36904429305856
    m_Localized: "\uAD00\uB9AC \uB2A5\uB825\uC774 \uD45C\uC2DC\uB429\uB2C8\uB2E4.
      \uB9E4\uB2C8\uC800\uAC00 \uBD80\uC871\uD558\uBA74 \uB9CC\uC871\uB3C4\uAC00
      \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 37440536854528
    m_Localized: "\uB9CC\uC871\uB3C4\uC5D0 \uC601\uD5A5\uC744 \uC8FC\uB294 \uC694\uC778\uC744
      \uC5EC\uAE30\uC11C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 37828904239104
    m_Localized: "\uD6A8\uC728\uC740 \uB9CC\uC871\uB3C4\uC5D0 \uB530\uB77C \uB2EC\uB77C\uC9C0\uBA70
      \uC0DD\uC0B0 \uC18D\uB3C4\uC5D0 \uC601\uD5A5\uC744 \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 38302378246144
    m_Localized: "\uC784\uAE08 \uC778\uC0C1\uC774 \uB9CC\uC871\uB3C4\uB97C \uC62C\uB9AC\uB294
      \uAC00\uC7A5 \uC26C\uC6B4 \uBC29\uBC95\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39086448852992
    m_Localized: "\uC6CC\uCEE4\xB7\uD14C\uD06C\uB2C8\uC158\uC740 \uAC74\uBB3C \uBC30\uCE58,
      \uC5F0\uAD6C\uC6D0\uC740 RP, \uB9E4\uB2C8\uC800\uB294 \uB9CC\uC871\uB3C4 \uD558\uB77D\uC744
      \uB9C9\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39688935456768
    m_Localized: "\uC5EC\uAE30\uC11C \uC9C1\uC6D0 \uACE0\uC6A9\xB7\uD574\uACE0\uB97C
      \uACB0\uC815\uD569\uB2C8\uB2E4. \uBAA8\uB450 \uD06C\uB808\uB527\uC774 \uB4ED\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2561770013474816
    m_Localized: "\uAC74\uBB3C \uD574\uAE08\uACFC \uC0DD\uC0B0\uC131 \uD5A5\uC0C1\uC774
      \uAC00\uB2A5\uD55C \uC5F0\uAD6C \uD328\uB110\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562082698838016
    m_Localized: "\uC5F0\uAD6C \uD3EC\uC778\uD2B8(RP)\uC640 \uD558\uB8E8 \uD68D\uB4DD\uB7C9\uC774
      \uC5EC\uAE30 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562316594200576
    m_Localized: "\uC5F0\uAD6C\uC6D0 \uC218\uC640 \uC801\uC6A9 \uC911\uC778 \uD6A8\uACFC\uB97C
      \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562738453102592
    m_Localized: "\uC644\uB8CC\uD55C \uC5F0\uAD6C\uB294 \uC0C9\uC73C\uB85C \uD45C\uC2DC\uB418\uACE0
      \uC21C\uC11C\uB300\uB85C \uD574\uAE08\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2563160425250816
    m_Localized: "\uD68C\uC0AC \uC131\uC7A5 \uCD94\uC774\uB97C \uD655\uC778\uD558\uB294
      \uC7AC\uBB34 \uD328\uB110\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2564533472608256
    m_Localized: "\uD604\uC7AC \uC6D4\uAC04 \uC131\uC7A5\uB960\uC744 \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2565297930649600
    m_Localized: "\uD604\uC7AC \uC6D4\uAC04 \uC774\uC775\uC744 \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2566859943985152
    m_Localized: "\uD604\uC7AC \uAE30\uC5C5 \uAC00\uCE58\uB97C \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2566981499109376
    m_Localized: "\uD604\uC7AC \uD06C\uB808\uB527\uC744 \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000000
    m_Localized: "\uB178\uC870 \uCC55\uD130\uB97C \uAD00\uB9AC\uD569\uB2C8\uB2E4.
      \uB9CC\uC871\uB3C4\uC5D0 \uB530\uB77C \uACB0\uD569\uB3C4\uAC00 \uBCC0\uD558\uACE0
      \uC694\uAD6C \uC644\uB8CC \uC2DC \uBCF4\uC0C1\uC774 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000001
    m_Localized: "\uCC55\uD130 \uB0A8\uC740 \uC77C\uC218\uC785\uB2C8\uB2E4. 0\uC774
      \uB418\uBA74 \uC885\uB8CC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000002
    m_Localized: "\uB9CC\uC871\uB3C4\uC5D0 \uB530\uB978 \uB0B4\uC77C \uACB0\uD569\uB3C4
      \uBCC0\uD654\uB97C \uBBF8\uB9AC \uBCF4\uC5EC \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000003
    m_Localized: "\uACB0\uD569\uB3C4(0~100%)\uB294 \uB9E4\uC77C \uBCC0\uD558\uBA70
      100%\uC5D0 \uB3C4\uB2EC\uD558\uBA74 \uC644\uB8CC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000004
    m_Localized: "\uC9C1\uC885\uBCC4 \uB9CC\uC871\uB3C4\uC785\uB2C8\uB2E4. \uAE09\uC5EC
      \uC870\uC815\uACFC \uC694\uAD6C \uC644\uB8CC\uAC00 \uD6A8\uACFC\uC801\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578000000000005
    m_Localized: "\uD65C\uC131 \uC694\uAD6C \uBAA9\uB85D\uC785\uB2C8\uB2E4. \uC870\uAC74
      \uCDA9\uC871 \uD6C4 \uD0ED\uD558\uBA74 \uC644\uB8CC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000000
    m_Localized: "\uC9C1\uC7A5 \uADDC\uCE59\uC744 \uCF1C\uACE0 \uB044\uBA70 \uC0DD\uC0B0\xB7\uB9CC\uC871\uB3C4\uC5D0
      \uC9C0\uC18D \uD6A8\uACFC\uB97C \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000001
    m_Localized: "\uAC01 \uC815\uCC45\uC744 \uCF1C\uAC70\uB098 \uB04C \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uD06C\uB808\uB527\xB7RP\uAC00 \uD544\uC694\uD55C \uAC83\uB3C4 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578100000000002
    m_Localized: "\uD65C\uC131 \uC815\uCC45\uACFC \uD6A8\uACFC\uAC00 \uC5EC\uAE30
      \uC694\uC57D\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000000
    m_Localized: "\uC2DC\uC7A5 \uBCC0\uD654, \uBA54\uC778 \uC774\uBCA4\uD2B8 \uB4F1
      \uD5E4\uB4DC\uB77C\uC778\uC774 \uC313\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000001
    m_Localized: "\uAE30\uC0AC \uBAA9\uB85D\uC744 \uC2A4\uD06C\uB864\uD569\uB2C8\uB2E4.
      \uC0C8 \uAE30\uC0AC\uAC00 \uCD94\uAC00\uB418\uACE0 \uAE30\uD55C\uC774 \uC9C0\uB098\uBA74
      \uC0AC\uB77C\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578200000000002
    m_Localized: "\uC81C\uBAA9\uC744 \uC5F4\uBA74 \uBCF8\uBB38\uC744 \uC77D\uC744
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000000
    m_Localized: "\uC120\uD0DD\uD55C \uAC74\uBB3C\uC758 \uC9C1\uC6D0, \uB808\uC2DC\uD53C,
      \uBC84\uD37C, \uC0DD\uC0B0\uC744 \uAD00\uB9AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000001
    m_Localized: ' maintenance'
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000002
    m_Localized: "\uC2AC\uB77C\uC774\uB354\uB85C \uC6CC\uCEE4\uC640 \uAE30\uC220\uC790\uB97C
      \uBC30\uCE58\uD569\uB2C8\uB2E4. \uC778\uC6D0\uC774 \uB9CE\uC744\uC218\uB85D
      \uD6A8\uC728\uC774 \uC62C\uB77C\uAC11\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000003
    m_Localized: "\uB808\uC2DC\uD53C \uC785\xB7\uCD9C\uB825\uC774 \uD45C\uC2DC\uB429\uB2C8\uB2E4.
      \uC0DD\uC0B0 \uBCC0\uACBD \uC2DC \uBC84\uD37C \uC790\uC6D0\uC774 \uBA3C\uC800
      \uBC18\uD658\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000004
    m_Localized: "\uC785\xB7\uCD9C\uB825 \uBC84\uD37C \uC790\uC6D0\uC785\uB2C8\uB2E4.
      \uC544\uC774\uCF58\uC744 \uB204\uB974\uBA74 \uC7AC\uACE0\uB85C \uB418\uB3CC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2578300000000005
    m_Localized: "\uD604\uC7AC \uBC30\uCE58\uC758 \uC0DD\uC0B0 \uC9C4\uD589\uB3C4\uC640
      \uC9C1\uC6D0 \uD6A8\uC728\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
