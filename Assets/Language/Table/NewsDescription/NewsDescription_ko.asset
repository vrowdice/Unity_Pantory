  m_TableData:
  - m_Id: 7000000000001
    m_Localized: "\uACE0\uC870\uB418\uB294 \uAD6D\uC81C \uAC08\uB4F1\uC73C\uB85C \uC778\uD574 \uAC01\uAD6D\uC774 \uAD6D\uBC29\uBE44\uB97C \uC99D\uC561\uD558\uBA70 \uC911\uD654\uAE30 \uC218\uC694\uAC00 \uAE09\uC99D\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000002
    m_Localized: "\uCD5C\uC2E0 \uCC28\uB7C9 \uBAA8\uB378\uC5D0 \uB300\uD55C \uAC11\uC791\uC2A4\uB7EC\uC6B4 \uC5F4\uD48D\uC73C\uB85C \uC804 \uC138\uACC4 \uB300\uB9AC\uC810\uC758 \uC7AC\uACE0\uAC00 \uB3D9\uB0AC\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000003
    m_Localized: "\uD601\uC2E0\uC801\uC778 \uC2E0\uD615 \uC5D4\uC9C4 \uC124\uACC4\uB85C \uC778\uD574 \uD56D\uACF5\uC6B0\uC8FC \uC0B0\uC5C5\uC5D0 \uD65C\uAE30\uAC00 \uB3CC\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000004
    m_Localized: "\uACF5\uAE09\uB9DD \uCC28\uC9C8\uB85C \uC778\uD574 \uBC18\uB3C4\uCCB4 \uC0DD\uC0B0\uC774 \uC911\uB2E8\uB418\uC5B4 \uBD80\uD488 \uAC00\uACA9\uC774 \uC0C1\uC2B9\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000005
    m_Localized: "\uC804 \uC138\uACC4\uC801\uC778 \uC1FC\uD551 \uC5F4\uD48D\uC73C\uB85C \uAC00\uC804\uC81C\uD488\uACFC \uC0DD\uD65C \uD544\uC218\uD488\uC5D0 \uB300\uD55C \uC218\uC694\uAC00 \uAE09\uC99D\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000006
    m_Localized: "\uC138\uACC4 \uACBD\uC81C \uBD88\uC548\uC815\uC73C\uB85C \uC548\uC804 \uC790\uC0B0\uC778 \uAE08\uC5D0 \uB300\uD55C \uC218\uC694\uAC00 \uD3ED\uBC1C\uC801\uC73C\uB85C \uC99D\uAC00\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000007
    m_Localized: "\uAE09\uACA9\uD55C \uB3C4\uC2DC\uD654\uB85C \uC778\uD574 \uAC74\uC124 \uC790\uC7AC\uC640 \uB3C4\uAD6C \uC218\uC694\uAC00 \uC0AC\uC0C1 \uCD5C\uACE0\uCE58\uB97C \uAE30\uB85D\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000008
    m_Localized: "\uC0C8\uB85C\uC6B4 \uC0AC\uCE58 \uAE08\uC9C0\uBC95\uC73C\uB85C \uC778\uD574 \uC5EC\uB7EC \uC8FC\uC694 \uC2DC\uC7A5\uC5D0\uC11C \uC0AC\uCE58\uD488 \uD310\uB9E4\uAC00 \uAE08\uC9C0\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000009
    m_Localized: "\uC138\uACC4 \uCD5C\uB300 \uAD6C\uB9AC \uAD11\uC0B0\uC5D0\uC11C \uBC1C\uC0DD\uD55C \uCE58\uBA85\uC801\uC778 \uBD95\uAD34 \uC0AC\uACE0\uB85C \uC6B4\uC601\uC774 \uBB34\uAE30\uD55C \uC911\uB2E8\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000010
    m_Localized: "\uC8FC\uC694 \uC6D0\uC720 \uC0DD\uC0B0 \uC9C0\uC5ED\uC758 \uC9C0\uC815\uD559\uC801 \uAE34\uC7A5\uC73C\uB85C \uC0DD\uC0B0\uB7C9\uC774 \uAE09\uAC10\uD558\uC5EC \uC720\uAC00\uAC00 \uAE09\uB4F1\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000011
    m_Localized: "\uC5ED\uC0AC\uC801\uC778 \uD3C9\uD654 \uD611\uC815\uC774 \uCCB4\uACB0\uB418\uC5B4 \uC804 \uC138\uACC4\uC801\uC73C\uB85C \uAD70\uC0AC \uC608\uC0B0\uC774 \uB300\uD3ED \uC0AD\uAC10\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000012
    m_Localized: "\uC911\uAE08\uC18D\uC5D0 \uB300\uD55C \uC0C8\uB85C\uC6B4 \uC218\uC785 \uAD00\uC138\uC640 \uBB34\uC5ED \uC81C\uD55C\uC73C\uB85C \uC778\uD574 \uAD6D\uB0B4 \uCCA0\uAC15 \uAC00\uACA9\uC774 \uAE09\uB4F1\uD588\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7000000000013
    m_Localized: "\uC12C\uC720 \uACF5\uC7A5\uC758 \uB300\uADDC\uBAA8 \uD30C\uC5C5\uC73C\uB85C \uC804 \uC138\uACC4 \uC758\uB958 \uC0DD\uC0B0\uC774 \uB9C8\uBE44\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
