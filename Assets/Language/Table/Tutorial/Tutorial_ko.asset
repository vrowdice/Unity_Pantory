  m_Name: Tutorial_ko
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: e00198e87a257ff41b02cc989c3a409a, type: 2}
  m_Metadata:
    m_Items:
    - rid: 2319839819189715043
  m_TableData:
  - m_Id: 11264212992
    m_Localized: "\uC548\uB155\uD558\uC138\uC694! \uD32C\uD1A0\uB9AC\uC5D0 \uC624\uC2E0
      \uAC83\uC744 \uD658\uC601\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items:
      - rid: 2319839819189715043
  - m_Id: 438890283008
    m_Localized: "\uD32C\uD1A0\uB9AC\uB294 \uACF5\uC7A5 \uACBD\uC601 \uC2DC\uBBAC\uB808\uC774\uC158
      \uAC8C\uC784\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 575934971904
    m_Localized: "\uBA3C\uC800 \uD50C\uB808\uC774 \uBC29\uBC95\uC744 \uC124\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uAC01 \uCC3D\uC758 \uBB3C\uC74C\uD45C \uBC84\uD2BC\uC73C\uB85C \uC5B8\uC81C\uB4E0
      \uD29C\uD1A0\uB9AC\uC5BC\uC744 \uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1678642659328
    m_Localized: "\uC67C\uCABD \uC704\uC758 \uD06C\uB808\uB527\xB7\uC5F0\uAD6C \uD3EC\uC778\uD2B8
      \uBC84\uD2BC\uC73C\uB85C \uC790\uAE08 \uD750\uB984\uC744 \uD655\uC778\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2291514359808
    m_Localized: "\uC774 \uC601\uC5ED\uC5D0\uB294 \uC9C1\uC6D0\uC758 \uACE0\uC6A9
      \uD604\uD669, \uBC30\uCE58, \uB9CC\uC871\uB3C4\uAC00 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2320476028928
    m_Localized: "\uC774 \uC601\uC5ED\uC5D0\uB294 \uC2DC\uACC4, \uC2DC\uAC04 \uC870\uC808,
      \uD29C\uD1A0\uB9AC\uC5BC, \uC124\uC815 \uBC84\uD2BC\uC774 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2777508364288
    m_Localized: "\uC8FC\uC694 \uD328\uB110\uB85C \uBE60\uB974\uAC8C \uC804\uD658\uD558\uB294
      \uBC84\uD2BC\uC740 \uC5EC\uAE30 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 5943566155776
    m_Localized: "\uC2A4\uB808\uB4DC\uC5D0 \uB300\uD574 \uC124\uBA85\uD569\uB2C8\uB2E4.
      \uC2A4\uB808\uB4DC\uB294 \uACF5\uC7A5\uB4E4\uC758 \uBB36\uC74C\uC774\uB77C\uACE0
      \uBCF4\uBA74 \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7203816095744
    m_Localized: "\uC2A4\uB808\uB4DC\uB97C \uB9CC\uB4E4\uBA74, \uADF8 \uC2A4\uB808\uB4DC\uC5D0
      \uBC30\uC815\uD55C \uC790\uC6D0\uC73C\uB85C \uC0C8 \uC790\uC6D0\uC744 \uC0DD\uC0B0\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7579063697408
    m_Localized: "\uC774 \uD328\uB110\uC5D0\uC11C \uC2A4\uB808\uB4DC\uB97C \uC124\uCE58\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC2A4\uB808\uB4DC\uB97C \uB9CC\uB4E4\uACE0
      \uC120\uD0DD\uD55C \uB4A4 \uBC30\uCE58\uD558\uBA74 \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7894026567680
    m_Localized: "\uC2A4\uB808\uB4DC \uC0DD\uC131 \uC2DC \uCE74\uD14C\uACE0\uB9AC\uB97C
      \uC815\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uADF8 \uCE74\uD14C\uACE0\uB9AC\uB85C
      \uBD84\uB958\uB418\uBA70, \uC774 \uD328\uB110\uC5D0\uC11C \uC2A4\uB808\uB4DC\uB97C
      \uD544\uD130\uB9C1\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8131256401920
    m_Localized: "\uC790\uC6D0\uC774 \uD575\uC2EC\uC785\uB2C8\uB2E4. \uBAA9\uD45C\uB294
      \uC790\uC6D0\uC744 \uC0DD\uC0B0\uD574 \uC2DC\uC7A5\uC5D0 \uD30C\uB294 \uAC83\uC785\uB2C8\uB2E4.
      \uC774 \uD328\uB110\uC5D0\uC11C \uD604\uC7AC \uC790\uC6D0 \uD604\uD669\uC744
      \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9056704413696
    m_Localized: "\uBA54\uC778 \uD328\uB110 \uC124\uBA85\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uC785\uB2C8\uB2E4.
      \uB2E4\uB978 \uD328\uB110\uC5D0\uB3C4 \uD29C\uD1A0\uB9AC\uC5BC\uC774 \uC788\uC73C\uB2C8
      \uC775\uD788\uBA74 \uB354 \uC990\uAE30\uC2E4 \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uD32C\uD1A0\uB9AC\uB97C \uC990\uACA8 \uC8FC\uC138\uC694. \uAC10\uC0AC\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 11779361357824
    m_Localized: "\uC774 \uBC84\uD2BC\uC73C\uB85C \uC2A4\uB808\uB4DC \uAC74\uC124
      \uBAA8\uB4DC\uC640 \uC81C\uAC70 \uBAA8\uB4DC\uB97C \uC804\uD658\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 12960301203456
    m_Localized: "\uC800\uC7A5\uC18C \uD328\uB110\uC785\uB2C8\uB2E4. \uD604\uC7AC
      \uBCF4\uC720\uD55C \uC790\uC6D0 \uC7AC\uACE0\uAC00 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 13340426780672
    m_Localized: "\uC790\uC6D0\uC5D0\uB294 \uCE74\uD14C\uACE0\uB9AC\uAC00 \uC788\uC73C\uBA70,
      \uC774 \uD328\uB110\uC5D0\uC11C \uCE74\uD14C\uACE0\uB9AC\uBCC4\uB85C \uD544\uD130\uB9C1\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 17836750028800
    m_Localized: "\uBC1C\uC8FC \uD328\uB110\uC785\uB2C8\uB2E4. \uAC01 \uADF8\uB8F9\uC774
      \uC790\uC6D0\uC744 \uC694\uCCAD\uD558\uACE0, \uC0AC\uC6A9\uC790\uAC00 \uC218\uB77D\uD55C
      \uB4A4 \uB0A9\uD488\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 17928651423744
    m_Localized: "\uBC1C\uC8FC\uB294 \uC2DC\uC7A5, \uAE30\uC5C5, \uC815\uBD80\uC5D0\uC11C
      \uC624\uBA70, \uADF8 \uC21C\uC11C\uB300\uB85C \uBC1C\uC8FC \uADDC\uBAA8\uAC00
      \uCEE4\uC9C0\uB294 \uD3B8\uC785\uB2C8\uB2E4. \uD68C\uC0AC \uC790\uC0B0\uC5D0
      \uB530\uB77C \uADDC\uBAA8\uB3C4 \uB2EC\uB77C\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 18539786682368
    m_Localized: "\uC5EC\uAE30\uC11C \uBC1C\uC8FC \uCD9C\uCC98\uBCC4\uB85C \uD544\uD130\uB9C1\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 18834268766208
    m_Localized: "\uBC1C\uC8FC\uB97C \uC218\uB77D\uD558\uBA74 \uC774 \uD1A0\uAE00\uB85C
      \uC218\uB77D\uD55C \uBC1C\uC8FC\uB97C \uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 19061579071488
    m_Localized: "\uD074\uB77C\uC774\uC5B8\uD2B8\uBCC4 \uBAA9\uB85D\uC740 \uC5EC\uAE30
      \uC788\uC2B5\uB2C8\uB2E4. \uD074\uB77C\uC774\uC5B8\uD2B8\uB97C \uD074\uB9AD\uD558\uBA74
      \uD574\uB2F9 \uD074\uB77C\uC774\uC5B8\uD2B8\uC6A9 \uBC1C\uC8FC \uBAA9\uB85D\uC774
      \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 19397370855424
    m_Localized: "\uC0C8 \uBC1C\uC8FC\uB294 \uC5EC\uAE30\uC5D0 \uD45C\uC2DC\uB429\uB2C8\uB2E4.
      \uD074\uB9AD\uD574\uC11C \uC218\uB77D\uD558\uBA74 \uC218\uB77D \uBC1C\uC8FC
      \uBAA9\uB85D\uC73C\uB85C \uC774\uB3D9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 19716532224000
    m_Localized: "\uC2DC\uC7A5 \uD328\uB110\uC785\uB2C8\uB2E4. \uC790\uC6D0 \uAC70\uB798\uC640
      \uACBD\uC7C1\uC0AC \uC815\uBCF4\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 22018345287680
    m_Localized: "\uC774 \uBC84\uD2BC\uC73C\uB85C \uC790\uC6D0 \uBCF4\uAE30\uC640
      \uAC70\uB798\uC790(\uACBD\uC7C1\uC0AC) \uBCF4\uAE30\uB97C \uC804\uD658\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 22020337582080
    m_Localized: "\uC790\uC6D0 \uBCF4\uAE30\uC785\uB2C8\uB2E4. \uD604\uC7AC \uC790\uC6D0\uC758
      \uAD6C\uB9E4\xB7\uD310\uB9E4\uB7C9\uC744 \uC5EC\uAE30\uC11C \uC870\uC808\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24215317528576
    m_Localized: "\uC790\uC6D0 \uC815\uBCF4\uB294 \uC5EC\uAE30\uC5D0 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24483870425088
    m_Localized: "\uC790\uC6D0 \uAC00\uACA9 \uCD94\uC774\uAC00 \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 24698149027840
    m_Localized: "\uAC70\uB798\uC790(\uACBD\uC7C1\uC0AC) \uBCF4\uAE30\uC785\uB2C8\uB2E4.
      \uAC01 \uAC70\uB798\uC790 \uC815\uBCF4\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 36510642880512
    m_Localized: "\uC9C1\uC6D0\uC744 \uAD00\uB9AC\uD558\uB294 \uD328\uB110\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 36904429305856
    m_Localized: "\uD604\uC7AC \uAD00\uB9AC \uB2A5\uB825\uC774 \uD45C\uC2DC\uB429\uB2C8\uB2E4.
      \uC9C1\uC6D0 \uC218\uC5D0 \uBE44\uD574 \uC77C\uC815 \uC218\uC758 \uB9E4\uB2C8\uC800\uAC00
      \uD544\uC694\uD558\uBA70, \uBD80\uC871\uD558\uBA74 \uB9CC\uC871\uB3C4\uAC00
      \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 37440536854528
    m_Localized: "\uC9C1\uC6D0 \uB9CC\uC871\uB3C4\uB294 \uC5EC\uB7EC \uC694\uC778\uC5D0
      \uB530\uB77C \uB2EC\uB77C\uC9D1\uB2C8\uB2E4. \uC5B4\uB5A4 \uC601\uD5A5\uC778\uC9C0\uB294
      \uC5EC\uAE30\uC11C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 37828904239104
    m_Localized: "\uC9C1\uC6D0 \uD6A8\uC728\uC740 \uB9CC\uC871\uB3C4\uC5D0 \uB530\uB77C
      \uB2EC\uB77C\uC9C0\uBA70, \uADF8 \uD6A8\uC728\uC774 \uC2A4\uB808\uB4DC \uC0DD\uC0B0\uC131\uC5D0
      \uC601\uD5A5\uC744 \uC90D\uB2C8\uB2E4. \uC694\uAD6C \uC0AC\uD56D\uB3C4 \uB9CC\uC871\uB3C4\uC5D0
      \uB530\uB77C \uBC14\uB01D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 38302378246144
    m_Localized: "\uB9CC\uC871\uB3C4\uB97C \uC62C\uB9AC\uB294 \uAC00\uC7A5 \uC26C\uC6B4
      \uBC29\uBC95\uC740 \uC784\uAE08 \uC778\uC0C1\uC785\uB2C8\uB2E4. \uB0AE\uCD94\uBA74
      \uB9CC\uC871\uB3C4\uAC00 \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39086448852992
    m_Localized: "\uC9C1\uC6D0\uC740 \uC6CC\uCEE4, \uD14C\uD06C\uB2C8\uC158, \uC5F0\uAD6C\uC6D0,
      \uB9E4\uB2C8\uC800\uB85C \uB098\uB269\uB2C8\uB2E4. \uC6CC\uCEE4\uB294 \uC2A4\uB808\uB4DC
      \uB0B4 \uB2E8\uC21C \uC791\uC5C5, \uD14C\uD06C\uB2C8\uC158\uC740 \uAE30\uC220
      \uC791\uC5C5, \uC5F0\uAD6C\uC6D0\uC740 RP(\uC5F0\uAD6C \uD3EC\uC778\uD2B8)
      \uC0DD\uC0B0, \uB9E4\uB2C8\uC800\uB294 \uC9C1\uC6D0 \uAD00\uB9AC\uB97C \uB2F4\uB2F9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39688935456768
    m_Localized: "\uC5EC\uAE30\uC11C \uC9C1\uC6D0 \uACE0\uC6A9\xB7\uD574\uACE0\uB97C
      \uACB0\uC815\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uACE0\uC6A9\xB7\uD574\uACE0\uC5D0\uB294
      \uD06C\uB808\uB527\uC774 \uB4E4\uACE0, \uD574\uACE0\uD558\uBA74 \uB9CC\uC871\uB3C4\uAC00
      \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2561770013474816
    m_Localized: "\uC5F0\uAD6C \uD328\uB110\uC785\uB2C8\uB2E4. \uAC74\uBB3C \uD574\uAE08\uACFC
      \uC0DD\uC0B0\uC131 \uD5A5\uC0C1\uC774 \uAC00\uB2A5\uD574\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562082698838016
    m_Localized: "\uC5F0\uAD6C \uD3EC\uC778\uD2B8(RP)\uC640 \uD558\uB8E8 \uD68D\uB4DD\uB7C9\uC774
      \uC5EC\uAE30 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562316594200576
    m_Localized: "\uC5F0\uAD6C\uC6D0 \uC218\uC640 \uC801\uC6A9 \uC911\uC778 \uD6A8\uACFC\uB97C
      \uBCFC \uC218 \uC788\uB294 \uD328\uB110\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2562738453102592
    m_Localized: "\uC5F0\uAD6C \uD2B8\uB9AC\uC785\uB2C8\uB2E4. \uC644\uB8CC\uD55C
      \uC5F0\uAD6C\uB294 \uC0C9\uC73C\uB85C \uD45C\uC2DC\uB418\uACE0, \uC774\uC5B4\uC9C0\uB294
      \uC5F0\uAD6C\uAC00 \uC21C\uC11C\uB300\uB85C \uD574\uAE08\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2563160425250816
    m_Localized: "\uC7AC\uBB34 \uD328\uB110\uC785\uB2C8\uB2E4. \uD68C\uC0AC \uC131\uC7A5
      \uCD94\uC774\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2564533472608256
    m_Localized: "\uD604\uC7AC \uC6D4\uAC04 \uC131\uC7A5\uB960\uC744 \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2565297930649600
    m_Localized: "\uD604\uC7AC \uC6D4\uAC04 \uC774\uC775\uC744 \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2566859943985152
    m_Localized: "\uD604\uC7AC \uAE30\uC5C5 \uAC00\uCE58\uB97C \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2566981499109376
    m_Localized: "\uD604\uC7AC \uD06C\uB808\uB527\uC744 \uADF8\uB798\uD504\uB85C
      \uD45C\uC2DC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2568369331388416
    m_Localized: "\uC548\uB155\uD558\uC138\uC694. \uB514\uC790\uC778 \uD654\uBA74\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uC2A4\uB808\uB4DC\uB97C \uC124\uACC4\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2568866050228224
    m_Localized: "\uC2A4\uB808\uB4DC \uC804\uCCB4 \uC870\uC791\uC740 \uC5EC\uAE30\uC11C
      \uD569\uB2C8\uB2E4. \uCD08\uAE30\uD654, \uC800\uC7A5, \uBD88\uB7EC\uC624\uAE30
      \uBC84\uD2BC\uC774 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2569802302767104
    m_Localized: "\uAC74\uBB3C\uC5D0\uB294 \uCE74\uD14C\uACE0\uB9AC\uAC00 \uC788\uC2B5\uB2C8\uB2E4.
      \uC0DD\uC0B0 \uAC74\uBB3C\uC740 \uC0DD\uC0B0, \uC720\uD1B5 \uAC74\uBB3C\uC740
      \uC720\uD1B5 \uCE74\uD14C\uACE0\uB9AC\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2571217918115840
    m_Localized: "\uCE74\uD14C\uACE0\uB9AC \uBC84\uD2BC\uC744 \uB204\uB974\uBA74
      \uAC01 \uAC74\uBB3C \uBC84\uD2BC\uC774 \uC5EC\uAE30 \uB098\uC635\uB2C8\uB2E4.
      \uBC84\uD2BC\uC744 \uB20C\uB7EC \uC120\uD0DD\uD558\uACE0 \uC2A4\uB808\uB4DC
      \uC124\uACC4\uC5D0 \uBC14\uB85C \uCD94\uAC00\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2571541005352960
    m_Localized: "\uC5EC\uAE30\uC11C \uC120\uD0DD\uD55C \uAC74\uBB3C\uC758 \uC124\uCE58
      \uBC29\uD5A5\uC744 \uBC14\uAFB8\uAC70\uB098, \uAC74\uC124\xB7\uC81C\uAC70 \uBAA8\uB4DC\uB97C
      \uC804\uD658\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2572921984139264
    m_Localized: "\uB514\uC790\uC778\uC5D0\uC11C\uB294 \u300C\uB3C4\uB85C\u300D\uAC00
      \uC911\uC694\uD569\uB2C8\uB2E4. \uC2A4\uB808\uB4DC \uD6A8\uC728\uC740 \uB3C4\uB85C
      \uC124\uACC4\uC5D0 \uB530\uB77C \uB2EC\uB77C\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2572931048030208
    m_Localized: "\uAC74\uBB3C\uC5D0\uB294 \uC785\uCD9C\uB825\uC774 \uC788\uACE0,
      \uC774\uAC78 \uB3C4\uB85C\uC5D0 \uB9DE\uCDB0 \uBC30\uCE58\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2575685451661312
    m_Localized: "\uC785\uB825\uC740 \uB2E4\uB978 \uAC74\uBB3C\uC758 \uCD9C\uB825\uC774\uB098
      \uD558\uC5ED\uC7A5\uC5D0 \uC5F0\uACB0\uD574\uC57C \uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2575868566585344
    m_Localized: "\uCD9C\uB825\uC744 \uAC70\uB798\uC18C\uC5D0 \uC5F0\uACB0\uD558\uBA74
      \uC2A4\uB808\uB4DC\uAC00 \uC644\uC131\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
