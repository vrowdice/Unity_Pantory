    m_Localized: "\u4E3B\u8981\u9271\u5C71\u3067\u306E\u58CA\u6EC5\u7684\u306A\u4E8B\u6545\u306B\u3088\u308A\u63A1\u6398\u304C\u505C\u6B62\u3057\u307E\u3057\u305F\u3002\u77F3\u70AD\u3001\u9244\u9271\u77F3\u3001\u30A2\u30EB\u30DF\u30CB\u30A6\u30E0\u9271\u77F3\u3001\u91D1\u9271\u77F3\u306E\u4E0D\u8DB3\u304C\u4E88\u60F3\u3055\u308C\u307E\u3059\u3002"
